---
import "../styles/global.css";
import { stegaClean } from "@sanity/client/stega";
import { getSiteSettings } from "../lib/queries";
import { getClient, isPreviewRequest, urlFor } from "../lib/sanity";
import VisualEditing from "../components/VisualEditing.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";

interface SeoBlock {
  metaTitle?: string;
  metaDescription?: string;
  ogImage?: { asset?: { _ref: string } };
  noIndex?: boolean;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: { asset?: { _ref: string } };
  seo?: SeoBlock;
  /** Override canonical URL — defaults to current page path */
  canonical?: string;
  /**
   * Nav theme. "dark" = transparent glass over a dark hero (homepage, ICP
   * pages). "light" = solid white from page top (interior pages, legal,
   * forms). Default "light".
   */
  navTheme?: "dark" | "light";
}

const { title, description, ogImage, seo, canonical, navTheme = "light" } = Astro.props;
const previewMode = isPreviewRequest(Astro);
const settings = await getSiteSettings(getClient(Astro));

// Compose final SEO values: page-specific seo block wins, then page-level
// props, then site-wide defaults from settings.
const defaultSeo: SeoBlock = settings?.defaultSeo ?? {};

// Strip stega zero-width characters from <title> and <meta> values. Stega
// encoding is fine for visible text inside the Studio iframe (the visual-
// editing overlay decodes it), but browsers display the zero-width chars
// as raw text in <title> bars and search engines treat them as part of
// the title. stegaClean is a no-op on plain strings.
const finalTitle = stegaClean(
  seo?.metaTitle ?? title ?? defaultSeo.metaTitle ?? "Team — The Operating System for Music Releases"
);
const finalDescription = stegaClean(
  seo?.metaDescription ?? description ?? defaultSeo.metaDescription ?? "Stop juggling spreadsheets, Slack threads, and email chains. One platform for your entire rollout."
);
const finalOgImage = seo?.ogImage ?? ogImage ?? defaultSeo.ogImage;
const ogImageUrl = finalOgImage?.asset?._ref
  ? urlFor(finalOgImage).width(1200).height(630).fit("crop").url()
  : "https://teamrollouts.com/og-image.png";

const noIndex = seo?.noIndex === true || previewMode;
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, Astro.site ?? "https://teamrollouts.com").toString();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{finalTitle}</title>
  <meta name="description" content={finalDescription} />
  {noIndex && <meta name="robots" content="noindex" />}
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={finalTitle} />
  <meta property="og:description" content={finalDescription} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={finalTitle} />
  <meta name="twitter:description" content={finalDescription} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Preconnect for fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  {/*
    Scroll position preservation across Visual Editing reloads.
    @sanity/astro's VisualEditing wrapper triggers window.location.reload()
    on every keystroke when the editor is typing in Studio's right panel,
    which jolts the iframe back to the top. Preserving scroll into
    sessionStorage on unload + restoring on load makes the reload nearly
    invisible — the editor sees the headline change in place while the
    page actually refreshes underneath.

    Only runs in preview mode (no point burning sessionStorage budget
    for ordinary visitors), and uses a generated key per-path so two
    different pages don't restore each other's scroll.
  */}
  {previewMode && (
    <script is:inline>{`
      (function () {
        var key = 'sve-scroll:' + location.pathname;
        try {
          var saved = sessionStorage.getItem(key);
          if (saved !== null) {
            var y = parseInt(saved, 10);
            if (!isNaN(y) && y > 0) {
              // Restore on next paint after layout settles
              window.addEventListener('load', function () {
                window.scrollTo(0, y);
              });
            }
          }
        } catch (e) {}
        window.addEventListener('beforeunload', function () {
          try { sessionStorage.setItem(key, String(window.scrollY)); } catch (e) {}
        });
      })();
    `}</script>
  )}

  <!-- Nav + footer CSS hoisted to head to prevent FOUC of large unstyled
       logo + plain-text link list when navigating between pages. -->
  <link rel="stylesheet" href="/components/nav.css" />
  <link rel="stylesheet" href="/components/footer.css" />

  <!-- Critical nav layout — inlined as a defensive measure so the nav
       NEVER renders unstyled even if /components/nav.css is delayed by
       cache misses or the CDN. Mirrors the layout-only rules from
       nav.css; full visual styling still comes from the linked file. -->
  <style is:inline>
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; padding: 0.875rem 2rem; display: flex; align-items: center; justify-content: space-between; max-width: 80rem; margin: 0 auto; }
    .nav__pill { display: flex; align-items: center; gap: 0.25rem; padding: 0.375rem 0.5rem; border-radius: 100px; background: rgba(255,255,255,0.12); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.1); }
    .nav__logo { display: flex; align-items: center; padding: 0 0.5rem; position: relative; }
    .nav__logo img { height: 1.125rem; }
    .nav__logo .logo-light { position: absolute; }
    .nav__logo .logo-dark { opacity: 0; }
    .nav__link, .nav__login { font-size: 0.8125rem; font-weight: 500; padding: 0.5rem 0.875rem; border-radius: 100px; color: rgba(255,255,255,0.85); white-space: nowrap; display: inline-flex; align-items: center; gap: 0.25rem; text-decoration: none; }
    .nav__login { padding: 0.5rem 1rem; border: 1px solid rgba(255,255,255,0.3); }
    .nav__cta { display: inline-flex; align-items: center; justify-content: center; font-size: 0.8125rem; font-weight: 600; padding: 0.625rem 1.25rem; border-radius: 100px; color: #fff; background: #111110; text-decoration: none; white-space: nowrap; }
    .nav__divider { width: 1px; height: 1rem; background: rgba(255,255,255,0.15); margin: 0 0.125rem; }
    .nav__dropdown { position: relative; }
    .nav__dropdown-panel { position: absolute; top: calc(100% + 0.75rem); left: 0; opacity: 0; visibility: hidden; pointer-events: none; }
    .nav__dropdown.is-open .nav__dropdown-panel { opacity: 1; visibility: visible; pointer-events: auto; }
    .nav__status { display: inline-flex; align-items: center; gap: 0.375rem; font-size: 0.75rem; padding: 0.375rem 0.625rem; border-radius: 100px; color: rgba(255,255,255,0.85); text-decoration: none; }
    .nav__status-dot { width: 6px; height: 6px; border-radius: 50%; background: #10b981; }
    .nav__burger { display: none; }
    .nav-mobile, .nav-mobile-overlay { display: none; }
    .nav a { text-decoration: none; }
    .nav a svg { fill: none; stroke: currentColor; }
  </style>

  <slot name="head" />
</head>
<body>
  {/*
    Legacy nav + footer — both auto-inject their CSS and build their own DOM
    into the placeholder divs below. data-theme controls nav appearance:
    "dark" = transparent over hero, "light" = solid from top of page.

    Source: components/nav.js + components/footer.js (copied to public/components/
    so Astro serves them at /components/*.js). Single source of truth lives
    in the legacy files for now; future work could migrate nav links into
    Sanity's siteSettings.navGroups but the legacy scripts are battle-tested.
  */}
  {/*
    Inject siteSettings as a global before nav.js / footer.js execute.
    `defer` runs scripts in document order after parsing, so the inline
    JSON below is guaranteed to be set before nav.js reads it. Each
    component falls back to its hardcoded structure when the global is
    absent or empty (rendering with `__TEAM_SITE__ = null` is a no-op).
  */}
  <script is:inline set:html={`window.__TEAM_SITE__ = ${JSON.stringify(settings ?? null)};`} />

  <div id="team-nav" data-theme={navTheme}>
    <Nav settings={settings} theme={navTheme} />
  </div>

  <main>
    <slot />
  </main>

  <Footer settings={settings} />

  <script src="/components/nav.js" defer></script>

  {/*
    Visual Editing overlay — always mount so Studio's Presentation tool
    can establish its postMessage connection with the iframe. Without
    stega encoding on public pages (sanityClient has stega disabled),
    the overlay has nothing to attach to outside Studio, so public
    visitors never see hover pencils or "Failed to decode stega"
    errors. Inside the iframe, the preview client emits stega and the
    overlay attaches pencils as expected.
  */}
  <VisualEditing />
</body>
</html>
