---
import "../styles/global.css";
import { stegaClean } from "@sanity/client/stega";
import { getSiteSettings } from "../lib/queries";
import { getClient, isPreviewRequest, urlFor } from "../lib/sanity";
import VisualEditing from "../components/VisualEditing.astro";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";

interface SeoBlock {
  metaTitle?: string;
  metaDescription?: string;
  ogImage?: { asset?: { _ref: string } };
  noIndex?: boolean;
}

interface Props {
  title?: string;
  description?: string;
  ogImage?: { asset?: { _ref: string } };
  seo?: SeoBlock;
  /** Override canonical URL — defaults to current page path */
  canonical?: string;
  /**
   * Nav theme. "dark" = transparent glass over a dark hero (homepage, ICP
   * pages). "light" = solid white from page top (interior pages, legal,
   * forms). Default "light".
   */
  navTheme?: "dark" | "light";
}

const { title, description, ogImage, seo, canonical, navTheme = "light" } = Astro.props;
const previewMode = isPreviewRequest(Astro);
const settings = await getSiteSettings(getClient(Astro));

// Compose final SEO values: page-specific seo block wins, then page-level
// props, then site-wide defaults from settings.
const defaultSeo: SeoBlock = settings?.defaultSeo ?? {};

// Strip stega zero-width characters from <title> and <meta> values. Stega
// encoding is fine for visible text inside the Studio iframe (the visual-
// editing overlay decodes it), but browsers display the zero-width chars
// as raw text in <title> bars and search engines treat them as part of
// the title. stegaClean is a no-op on plain strings.
const finalTitle = stegaClean(
  seo?.metaTitle ?? title ?? defaultSeo.metaTitle ?? "Team — The Operating System for Music Releases"
);
const finalDescription = stegaClean(
  seo?.metaDescription ?? description ?? defaultSeo.metaDescription ?? "Stop juggling spreadsheets, Slack threads, and email chains. One platform for your entire rollout."
);
const finalOgImage = seo?.ogImage ?? ogImage ?? defaultSeo.ogImage;
const ogImageUrl = finalOgImage?.asset?._ref
  ? urlFor(finalOgImage).width(1200).height(630).fit("crop").url()
  : "https://teamrollouts.com/og-image.png";

const noIndex = seo?.noIndex === true || previewMode;
const canonicalUrl =
  canonical ?? new URL(Astro.url.pathname, Astro.site ?? "https://teamrollouts.com").toString();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{finalTitle}</title>
  <meta name="description" content={finalDescription} />
  {noIndex && <meta name="robots" content="noindex" />}
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:title" content={finalTitle} />
  <meta property="og:description" content={finalDescription} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={finalTitle} />
  <meta name="twitter:description" content={finalDescription} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Preconnect for fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Nav + footer CSS hoisted to head to prevent FOUC of large unstyled
       logo + plain-text link list when navigating between pages. -->
  <link rel="stylesheet" href="/components/nav.css" />
  <link rel="stylesheet" href="/components/footer.css" />

  <slot name="head" />
</head>
<body>
  {/*
    Legacy nav + footer — both auto-inject their CSS and build their own DOM
    into the placeholder divs below. data-theme controls nav appearance:
    "dark" = transparent over hero, "light" = solid from top of page.

    Source: components/nav.js + components/footer.js (copied to public/components/
    so Astro serves them at /components/*.js). Single source of truth lives
    in the legacy files for now; future work could migrate nav links into
    Sanity's siteSettings.navGroups but the legacy scripts are battle-tested.
  */}
  {/*
    Inject siteSettings as a global before nav.js / footer.js execute.
    `defer` runs scripts in document order after parsing, so the inline
    JSON below is guaranteed to be set before nav.js reads it. Each
    component falls back to its hardcoded structure when the global is
    absent or empty (rendering with `__TEAM_SITE__ = null` is a no-op).
  */}
  <script is:inline set:html={`window.__TEAM_SITE__ = ${JSON.stringify(settings ?? null)};`} />

  <div id="team-nav" data-theme={navTheme}>
    <Nav settings={settings} theme={navTheme} />
  </div>

  <main>
    <slot />
  </main>

  <Footer settings={settings} />

  <script src="/components/nav.js" defer></script>

  {/*
    Visual Editing overlay — always mount so Studio's Presentation tool
    can establish its postMessage connection with the iframe. Without
    stega encoding on public pages (sanityClient has stega disabled),
    the overlay has nothing to attach to outside Studio, so public
    visitors never see hover pencils or "Failed to decode stega"
    errors. Inside the iframe, the preview client emits stega and the
    overlay attaches pencils as expected.
  */}
  <VisualEditing />
</body>
</html>
