---
/**
 * "Up and running in minutes" — 3-step block on every ICP page.
 */

import SplitHeadline from "../SplitHeadline.astro";

interface StepItem {
  number: string;
  title: string;
  description: string;
}

interface Props {
  value?: {
    eyebrow?: string;
    headlineTop?: string;
    headlineBottom?: string;
    headline?: string;
    steps?: StepItem[];
  };
}

const { value } = Astro.props;
if (!value || !value.steps || value.steps.length === 0) return null;
const top = value.headlineTop ?? value.headline ?? null;
const bottom = value.headlineBottom ?? null;
const hasHeadline = !!(top || bottom);
---

<section class="steps-block">
  <div class="container">
    <div class="steps-intro">
      {value.eyebrow && <span class="label-sm">{value.eyebrow}</span>}
      {hasHeadline && <SplitHeadline as="h2" class="headline-lg" top={top} bottom={bottom} />}
    </div>

    <ol class="steps-grid">
      {
        value.steps.map((step) => (
          <li class="step-card">
            <span class="step-number">{step.number}</span>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .steps-block {
    padding: 6rem 0;
  }
  .steps-intro {
    text-align: center;
    margin-bottom: 3rem;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
    list-style: none;
  }
  .step-card {
    position: relative;
    padding: 1.5rem 0;
  }
  .step-number {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 1rem;
    letter-spacing: 0.06em;
  }
  .step-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .step-card p {
    color: var(--text-secondary);
    line-height: 1.6;
  }
</style>
