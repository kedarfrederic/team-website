---
/**
 * "Designed for how you work" — 4-card roles grid.
 * Cross-link block on enterprise/about/intelligence/orchestration/integrations.
 */

interface RoleCard {
  title: string;
  description: string;
  href: string;
}

interface Props {
  value?: {
    eyebrow?: string;
    headline?: string;
    cards?: RoleCard[];
  };
}

const { value } = Astro.props;
if (!value || !value.cards || value.cards.length === 0) return null;
---

<section class="roles-grid-block">
  <div class="container">
    <div class="roles-intro">
      {value.eyebrow && <span class="label-sm">{value.eyebrow}</span>}
      {value.headline && <h2 class="headline-lg">{value.headline}</h2>}
    </div>

    <div class="roles-grid">
      {
        value.cards.map((card) => (
          <a href={card.href} class="role-card">
            <h3>{card.title}</h3>
            <p>{card.description}</p>
            <span class="role-card__arrow" aria-hidden="true">→</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .roles-grid-block {
    padding: 6rem 0;
  }
  .roles-intro {
    text-align: center;
    margin-bottom: 3rem;
  }
  .roles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .role-card {
    position: relative;
    display: block;
    padding: 1.5rem 1.75rem;
    border: 1px solid var(--grey);
    border-radius: 16px;
    transition: border-color 0.2s, transform 0.2s, background 0.2s;
    background: #fff;
  }
  .role-card:hover {
    border-color: #111;
    transform: translateY(-2px);
  }
  .role-card h3 {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .role-card p {
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.55;
    padding-right: 1.5rem;
  }
  .role-card__arrow {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    color: var(--accent);
    font-weight: 600;
    transition: transform 0.2s;
  }
  .role-card:hover .role-card__arrow {
    transform: translateX(2px);
  }
</style>
