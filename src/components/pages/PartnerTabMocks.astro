  </div>
</div>
<div class="partner-preview-item" data-preview="creative-3">
  <div class="mock-collab">
    <div class="mock-collab__row"><div class="mock-collab__avatar" style="background:#8B5CF6">CR</div><div class="mock-collab__task">Submitted artwork v3 for review</div><div class="mock-collab__check"></div></div>
