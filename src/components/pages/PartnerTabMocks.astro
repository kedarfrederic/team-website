---
/**
 * Tab preview mocks for /for-partners. The tabs (Marketing & PR /
 * Distribution / A&R / Creative Services) each have 4 feature buttons
 * that switch which mock panel shows. The mocks themselves are intricate
 * one-off product illustrations — keeping them as static fixtures here
 * rather than schema-driving them, since editors won't realistically
 * tweak Gantt-bar widths per partner type.
 *
 * Each mock is keyed by `${tabKey}-${index+1}` (e.g. `marketing-1`).
 * Tab keys are: marketing | distribution | ar | creative
 */
---

{/* Marketing & PR */}
<div class="partner-preview-item is-active" data-preview="marketing-1">
  <div class="fp-timeline">
    <div class="fp-timeline__row"><div class="fp-timeline__label">Teaser</div><div class="fp-timeline__track"><div class="fp-timeline__bar" style="left:0%;width:25%;background:linear-gradient(90deg,#F56002,#ff8533)"></div></div></div>
    <div class="fp-timeline__row"><div class="fp-timeline__label">Press</div><div class="fp-timeline__track"><div class="fp-timeline__bar" style="left:15%;width:35%;background:linear-gradient(90deg,#3B82F6,#60a5fa)"></div></div></div>
    <div class="fp-timeline__row"><div class="fp-timeline__label">Social</div><div class="fp-timeline__track"><div class="fp-timeline__bar" style="left:30%;width:40%;background:linear-gradient(90deg,#8B5CF6,#a78bfa)"></div></div></div>
    <div class="fp-timeline__row"><div class="fp-timeline__label">Ads</div><div class="fp-timeline__track"><div class="fp-timeline__bar" style="left:50%;width:30%;background:linear-gradient(90deg,#EC4899,#f472b6)"></div></div></div>
    <div class="fp-timeline__row"><div class="fp-timeline__label">Launch</div><div class="fp-timeline__track"><div class="fp-timeline__bar" style="left:75%;width:20%;background:linear-gradient(90deg,#FAD604,#fbe046)"></div></div></div>
  </div>
</div>
<div class="partner-preview-item" data-preview="marketing-2">
  <div class="fp-tasks">
    <div class="fp-tasks__row"><div class="fp-tasks__check fp-tasks__check--done"></div><div class="fp-tasks__label fp-tasks__label--done">Pitch to NME</div><div class="fp-tasks__assignee" style="background:#3B82F6">PR</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check fp-tasks__check--done"></div><div class="fp-tasks__label fp-tasks__label--done">Pitch to Complex</div><div class="fp-tasks__assignee" style="background:#3B82F6">PR</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check"></div><div class="fp-tasks__label">Follow up — Pitchfork</div><div class="fp-tasks__assignee" style="background:#EC4899">MK</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check"></div><div class="fp-tasks__label">Submit playlist pitch</div><div class="fp-tasks__assignee" style="background:#EC4899">MK</div></div>
  </div>
</div>
<div class="partner-preview-item" data-preview="marketing-3">
  <div class="mock-gantt">
    <div class="mock-gantt__row"><div class="mock-gantt__label">TikTok</div><div class="mock-gantt__track"><div class="mock-gantt__bar" style="left:0%;width:60%;background:linear-gradient(90deg,#191919,#333)"></div></div></div>
    <div class="mock-gantt__row"><div class="mock-gantt__label">Instagram</div><div class="mock-gantt__track"><div class="mock-gantt__bar" style="left:10%;width:55%;background:linear-gradient(90deg,#EC4899,#f472b6)"></div></div></div>
    <div class="mock-gantt__row"><div class="mock-gantt__label">X</div><div class="mock-gantt__track"><div class="mock-gantt__bar" style="left:20%;width:50%;background:linear-gradient(90deg,#3B82F6,#60a5fa)"></div></div></div>
    <div class="mock-gantt__row"><div class="mock-gantt__label">YouTube</div><div class="mock-gantt__track"><div class="mock-gantt__bar" style="left:30%;width:65%;background:linear-gradient(90deg,#dc2626,#ef4444)"></div></div></div>
  </div>
</div>
<div class="partner-preview-item" data-preview="marketing-4">
  <div class="fp-budget">
    <div class="fp-budget__bar-group">
      <div class="fp-budget__bar-row"><div class="fp-budget__bar-label">Ads</div><div class="fp-budget__bar-track"><div class="fp-budget__bar-fill" style="width:65%;background:linear-gradient(90deg,#3B82F6,#60a5fa)"></div></div><div class="fp-budget__bar-value">$8.2k</div></div>
      <div class="fp-budget__bar-row"><div class="fp-budget__bar-label">PR</div><div class="fp-budget__bar-track"><div class="fp-budget__bar-fill" style="width:40%;background:linear-gradient(90deg,#8B5CF6,#a78bfa)"></div></div><div class="fp-budget__bar-value">$5.0k</div></div>
      <div class="fp-budget__bar-row"><div class="fp-budget__bar-label">Content</div><div class="fp-budget__bar-track"><div class="fp-budget__bar-fill" style="width:30%;background:linear-gradient(90deg,#EC4899,#f472b6)"></div></div><div class="fp-budget__bar-value">$3.8k</div></div>
    </div>
    <div class="fp-budget__total"><span>Campaign Total</span><span>$17.0k</span></div>
  </div>
</div>

{/* Distribution */}
