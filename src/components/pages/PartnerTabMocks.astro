    <div class="mock-dashboard__row">
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Spotify</div><div class="mock-dashboard__card-value">Delivered</div><div class="mock-dashboard__pill mock-dashboard__pill--green">Live</div></div>
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Apple Music</div><div class="mock-dashboard__card-value">Delivered</div><div class="mock-dashboard__pill mock-dashboard__pill--green">Live</div></div>
    </div>
    <div class="mock-dashboard__row">
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Amazon</div><div class="mock-dashboard__card-value">Processing</div><div class="mock-dashboard__pill mock-dashboard__pill--amber">In Progress</div></div>
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">YouTube Music</div><div class="mock-dashboard__card-value">Pending</div><div class="mock-dashboard__pill mock-dashboard__pill--amber">Queued</div></div>
    </div>
  </div>
</div>
<div class="partner-preview-item" data-preview="distribution-2">
  <div class="fp-tasks">
    <div class="fp-tasks__row"><div class="fp-tasks__check fp-tasks__check--done"></div><div class="fp-tasks__label fp-tasks__label--done">ISRC codes assigned</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check fp-tasks__check--done"></div><div class="fp-tasks__label fp-tasks__label--done">UPC barcode generated</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check fp-tasks__check--done"></div><div class="fp-tasks__label fp-tasks__label--done">Track titles validated</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check"></div><div class="fp-tasks__label">Explicit content flag — review</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check"></div><div class="fp-tasks__label">Genre classification — confirm</div></div>
  </div>
</div>
<div class="partner-preview-item" data-preview="distribution-3">
  <div class="mock-collab">
    <div class="mock-collab__row"><div class="mock-collab__avatar" style="background:#D9FA87;color:var(--black)">!</div><div class="mock-collab__task">Mara — Golden Hour delivered to all DSPs</div><div class="mock-collab__check mock-collab__check--done"></div></div>
    <div class="mock-collab__row"><div class="mock-collab__avatar" style="background:#D9FA87;color:var(--black)">!</div><div class="mock-collab__task">Ash Velo — First Light EP processing on Spotify</div><div class="mock-collab__check"></div></div>
    <div class="mock-collab__row"><div class="mock-collab__avatar" style="background:rgba(239,68,68,0.1);color:#dc2626">!</div><div class="mock-collab__task">Kira — Late Bloom rejected: artwork too small</div><div class="mock-collab__check"></div></div>
  </div>
</div>
<div class="partner-preview-item" data-preview="distribution-4">
  <div class="mock-dashboard">
    <div class="mock-dashboard__row">
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Audio Files</div><div class="mock-dashboard__card-value">24</div><div class="mock-dashboard__pill mock-dashboard__pill--green">Uploaded</div></div>
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Artwork</div><div class="mock-dashboard__card-value">8</div><div class="mock-dashboard__pill mock-dashboard__pill--green">Verified</div></div>
    </div>
    <div class="mock-dashboard__row">
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Metadata</div><div class="mock-dashboard__card-value">6 releases</div><div class="mock-dashboard__pill mock-dashboard__pill--amber">2 pending</div></div>
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Storage</div><div class="mock-dashboard__card-value">4.2 GB</div><div class="mock-dashboard__pill mock-dashboard__pill--green">OK</div></div>
    </div>
  </div>
</div>

{/* A&R */}
<div class="partner-preview-item is-active" data-preview="ar-1">
  <div class="mock-dashboard">
    <div class="mock-dashboard__row"><div class="mock-dashboard__card"><div class="mock-dashboard__card-title">New Demos</div><div class="mock-dashboard__card-value">12</div><div class="mock-dashboard__pill mock-dashboard__pill--amber">To Review</div></div></div>
    <div class="mock-dashboard__row"><div class="mock-dashboard__card"><div class="mock-dashboard__card-title">In Review</div><div class="mock-dashboard__card-value">5</div><div class="mock-dashboard__pill mock-dashboard__pill--green">In Progress</div></div></div>
