    </div>
  </div>
</div>
<div class="partner-preview-item" data-preview="creative-2">
  <div class="fp-tasks">
    <div class="fp-tasks__row"><div class="fp-tasks__check fp-tasks__check--done"></div><div class="fp-tasks__label fp-tasks__label--done">Album artwork v1 — rejected</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check fp-tasks__check--done"></div><div class="fp-tasks__label fp-tasks__label--done">Album artwork v2 — revisions requested</div></div>
