  </div>
</div>
<div class="partner-preview-item" data-preview="creative-4">
  <div class="mock-collab">
    <div class="mock-collab__row"><div class="mock-collab__avatar" style="background:#D9FA87;color:var(--black)">!</div><div class="mock-collab__task">Album artwork v3 — due in 2 days</div><div class="mock-collab__check"></div></div>
    <div class="mock-collab__row"><div class="mock-collab__avatar" style="background:#D9FA87;color:var(--black)">!</div><div class="mock-collab__task">Social content kit — due in 5 days</div><div class="mock-collab__check"></div></div>
    <div class="mock-collab__row"><div class="mock-collab__avatar" style="background:rgba(0,0,0,0.08);color:var(--text-secondary)">&#10003;</div><div class="mock-collab__task" style="text-decoration:line-through;opacity:0.5">Press photos — delivered</div><div class="mock-collab__check mock-collab__check--done"></div></div>
  </div>
</div>
