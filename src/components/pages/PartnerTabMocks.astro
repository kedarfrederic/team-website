  </div>
</div>
<div class="partner-preview-item" data-preview="ar-2">
  <div class="fp-tasks">
    <div class="fp-tasks__row"><div class="fp-tasks__check fp-tasks__check--done"></div><div class="fp-tasks__label fp-tasks__label--done">Recording sessions booked</div><div class="fp-tasks__assignee" style="background:#8B5CF6">AR</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check fp-tasks__check--done"></div><div class="fp-tasks__label fp-tasks__label--done">Producer selected</div><div class="fp-tasks__assignee" style="background:#8B5CF6">AR</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check"></div><div class="fp-tasks__label">Brand partnership outreach</div><div class="fp-tasks__assignee" style="background:#F56002">MG</div></div>
    <div class="fp-tasks__row"><div class="fp-tasks__check"></div><div class="fp-tasks__label">Visual identity development</div><div class="fp-tasks__assignee" style="background:#EC4899">CR</div></div>
  </div>
</div>
<div class="partner-preview-item" data-preview="ar-3">
  <div class="analytics-grid">
    <div class="analytics-tile">
      <div class="analytics-tile__label">Streams</div>
      <div class="analytics-tile__value">2.4M</div>
      <div class="analytics-bars">
        <div class="analytics-bars__bar" style="height:45%"></div>
        <div class="analytics-bars__bar" style="height:62%"></div>
        <div class="analytics-bars__bar" style="height:38%"></div>
        <div class="analytics-bars__bar" style="height:78%"></div>
        <div class="analytics-bars__bar" style="height:55%"></div>
        <div class="analytics-bars__bar" style="height:90%"></div>
        <div class="analytics-bars__bar" style="height:72%"></div>
        <div class="analytics-bars__bar" style="height:85%"></div>
        <div class="analytics-bars__bar" style="height:60%"></div>
        <div class="analytics-bars__bar" style="height:95%"></div>
        <div class="analytics-bars__bar" style="height:80%"></div>
        <div class="analytics-bars__bar" style="height:100%"></div>
        <div class="analytics-bars__bar" style="height:68%"></div>
        <div class="analytics-bars__bar" style="height:52%"></div>
      </div>
    </div>
    <div class="analytics-tile">
      <div class="analytics-tile__label">Saves</div>
      <div class="analytics-tile__value">18.2k</div>
      <div class="analytics-hearts" id="heartsContainer"></div>
    </div>
    <div class="analytics-tile">
      <div class="analytics-tile__label">Playlists</div>
      <div class="analytics-tile__value">342</div>
      <div class="analytics-tags">
        <span class="analytics-tags__tag">New Music Friday</span>
        <span class="analytics-tags__tag">Indie Pop</span>
        <span class="analytics-tags__tag">Chill Vibes</span>
        <span class="analytics-tags__tag">Release Radar</span>
        <span class="analytics-tags__tag">Alt Rising</span>
        <span class="analytics-tags__tag">Fresh Finds</span>
        <span class="analytics-tags__tag">+336</span>
      </div>
    </div>
    <div class="analytics-tile">
      <div class="analytics-tile__label">Reach</div>
      <div class="analytics-reach" data-countup="890000">0</div>
      <div class="mock-dashboard__pill mock-dashboard__pill--green" style="margin-top:auto">+12% this week</div>
    </div>
  </div>
</div>
<div class="partner-preview-item" data-preview="ar-4">
  <div class="mock-dashboard">
    <div class="mock-dashboard__row">
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Genre Trend</div><div class="mock-dashboard__card-value">+14%</div><div class="mock-dashboard__pill mock-dashboard__pill--green">Rising</div></div>
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Similar Artists</div><div class="mock-dashboard__card-value">28</div><div class="mock-dashboard__pill mock-dashboard__pill--green">Mapped</div></div>
    </div>
    <div class="mock-dashboard__row">
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Market Gap</div><div class="mock-dashboard__card-value">Found</div><div class="mock-dashboard__pill mock-dashboard__pill--amber">Opportunity</div></div>
      <div class="mock-dashboard__card"><div class="mock-dashboard__card-title">Audience</div><div class="mock-dashboard__card-value">18-24</div><div class="mock-dashboard__pill mock-dashboard__pill--green">Primary</div></div>
    </div>
  </div>
</div>

{/* Creative Services */}
<div class="partner-preview-item is-active" data-preview="creative-1">
  <div class="mock-dashboard">
