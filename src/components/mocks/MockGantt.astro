---
/**
 * Fake Gantt-style timeline — bars positioned by startWeek + spanWeeks
 * across N week columns. Pure CSS grid, no chart library.
 */

interface GanttRow {
  label?: string;
  category?: "marketing" | "production" | "distribution" | "promotion" | "other";
  startWeek?: number;
  spanWeeks?: number;
}

interface Props {
  value?: {
    weeks?: number;
    rows?: GanttRow[];
  };
}

const { value } = Astro.props;
const weeks = value?.weeks ?? 8;
const rows = value?.rows ?? [];
const categoryColors: Record<string, string> = {
  marketing: "var(--accent)",
  production: "#5679b5",
  distribution: "#A0C9CB",
  promotion: "#f1a636",
  other: "#885d73",
};
---

<div class="mock-gantt" style={`--weeks: ${weeks}`}>
  <header class="mock-gantt__header">
    {Array.from({ length: weeks }, (_, i) => (
      <span class="mock-gantt__week">W{i + 1}</span>
    ))}
  </header>
  <ul class="mock-gantt__rows">
    {
      rows.map((row) => {
        const start = Math.max(1, row.startWeek ?? 1);
        const span = Math.max(1, row.spanWeeks ?? 1);
        const color = categoryColors[row.category ?? "other"] ?? categoryColors.other;
        return (
          <li class="mock-gantt__row">
            <span class="mock-gantt__label">{row.label}</span>
            <div class="mock-gantt__track">
              <span
                class="mock-gantt__bar"
                style={`--start:${start}; --span:${span}; --color:${color};`}
              />
            </div>
          </li>
        );
      })
    }
  </ul>
</div>

<style>
  .mock-gantt {
    width: 100%;
    padding: 1rem;
    font-size: 0.6875rem;
    background: #fff;
    border: 1px solid var(--grey);
    border-radius: 8px;
  }
  .mock-gantt__header {
    display: grid;
    grid-template-columns: 80px repeat(var(--weeks), 1fr);
    gap: 2px;
    margin-bottom: 0.5rem;
    padding-left: 80px;
  }
  .mock-gantt__week {
    font-weight: 600;
    color: var(--text-secondary);
    font-size: 0.625rem;
    text-align: center;
  }
  .mock-gantt__rows {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .mock-gantt__row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.5rem;
    align-items: center;
  }
  .mock-gantt__label {
    font-size: 0.625rem;
    color: #111;
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .mock-gantt__track {
    display: grid;
    grid-template-columns: repeat(var(--weeks), 1fr);
    gap: 2px;
    height: 18px;
    background: var(--bg);
    border-radius: 4px;
    padding: 2px;
  }
  .mock-gantt__bar {
    grid-column: var(--start) / span var(--span);
    background: var(--color);
    border-radius: 3px;
  }
</style>
