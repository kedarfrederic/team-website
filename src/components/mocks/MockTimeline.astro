---
/**
 * Fake day-by-day rollout timeline — N day columns with task cards inside.
 */

interface TimelineTask {
  day?: string;
  title?: string;
  time?: string;
  status?: "done" | "in_progress" | "upcoming" | "blocked";
  category?: "marketing" | "distribution" | "promotion" | "production" | "other";
  assignees?: string[];
}

interface Props {
  value?: {
    columns?: string[];
    tasks?: TimelineTask[];
  };
}

const { value } = Astro.props;
const columns = value?.columns ?? [];
const tasks = value?.tasks ?? [];

const statusColors: Record<string, string> = {
  done: "#A0C9CB",
  in_progress: "var(--accent-lime)",
  upcoming: "#e0e0e0",
  blocked: "#f1a636",
};

const categoryDots: Record<string, string> = {
  marketing: "var(--accent)",
  distribution: "#5679b5",
  promotion: "#f1a636",
  production: "#885d73",
  other: "#71717a",
};
---

<div class="mock-timeline" style={`--cols:${columns.length}`}>
  <header class="mock-timeline__header">
    {columns.map((col) => <span class="mock-timeline__col-head">{col}</span>)}
  </header>
  <div class="mock-timeline__body">
    {
      columns.map((col) => (
        <div class="mock-timeline__col">
          {tasks
            .filter((t) => t.day === col)
            .map((t) => (
              <article
                class="mock-timeline__task"
                style={`--accent:${statusColors[t.status ?? "upcoming"] ?? statusColors.upcoming};`}
              >
                {t.time && <span class="mock-timeline__time">{t.time}</span>}
                <p class="mock-timeline__title">{t.title}</p>
                <div class="mock-timeline__meta">
                  {t.category && (
                    <span
                      class="mock-timeline__dot"
                      style={`background:${categoryDots[t.category] ?? categoryDots.other};`}
                    />
                  )}
                  {t.assignees && t.assignees.length > 0 && (
                    <ul class="mock-timeline__assignees">
                      {t.assignees.map((a) => (
                        <li>{a}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </article>
            ))}
        </div>
      ))
    }
  </div>
</div>

<style>
  .mock-timeline {
    width: 100%;
    background: #fff;
    border: 1px solid var(--grey);
    border-radius: 8px;
    overflow: hidden;
  }
  .mock-timeline__header,
  .mock-timeline__body {
    display: grid;
    grid-template-columns: repeat(var(--cols), 1fr);
  }
  .mock-timeline__col-head {
    padding: 0.5rem;
    text-align: center;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    background: var(--bg);
    border-right: 1px solid var(--grey);
  }
  .mock-timeline__col-head:last-child {
    border-right: none;
  }
  .mock-timeline__col {
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-height: 140px;
    border-right: 1px solid var(--grey);
  }
  .mock-timeline__col:last-child {
    border-right: none;
  }
  .mock-timeline__task {
    background: var(--bg);
    border-left: 3px solid var(--accent);
    padding: 0.375rem 0.5rem;
    border-radius: 0 4px 4px 0;
    font-size: 0.625rem;
  }
  .mock-timeline__time {
    color: var(--text-secondary);
    font-size: 0.5625rem;
  }
  .mock-timeline__title {
    color: #111;
    font-weight: 500;
    line-height: 1.3;
    margin: 0.125rem 0;
  }
  .mock-timeline__meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    margin-top: 0.25rem;
  }
  .mock-timeline__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }
  .mock-timeline__assignees {
    list-style: none;
    display: flex;
    margin-left: auto;
  }
  .mock-timeline__assignees li {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #111;
    color: #fff;
    font-size: 0.5rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: -3px;
    border: 1.5px solid #fff;
  }
</style>
