---
/**
 * Sanity Visual Editing overlay — wraps our custom React client that
 * bypasses @sanity/astro's hardcoded full-page-reload refresh handler.
 * Without this wrapper, every keystroke in Studio fires
 * window.location.reload() — losing scroll, restarting animations, and
 * dropping the editor back at the top of the page.
 *
 * Toggle via the `PUBLIC_SANITY_VISUAL_EDITING_ENABLED` env var:
 *   - "true" or unset → mount the overlay on every request
 *   - "false"          → no overlay code ships
 */
import VisualEditingClient from "./VisualEditingClient";

const enabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED !== "false";
---

{enabled && <VisualEditingClient client:only="react" zIndex={1000} />}
