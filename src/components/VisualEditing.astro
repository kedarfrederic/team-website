---
/**
 * Sanity Visual Editing overlay — uses the canonical component from
 * `@sanity/astro/visual-editing`. It's a React component under the hood
 * (rendered with `client:only="react"` so it never SSRs) that handles
 * iframe detection, comlink handshake with Studio's Presentation tool,
 * and click-to-edit pencil rendering.
 *
 * Toggle via the `PUBLIC_SANITY_VISUAL_EDITING_ENABLED` env var:
 *   - "true"  → mount the overlay on every request
 *   - else    → no overlay code ships
 *
 * The component itself is also iframe-aware — even when enabled, it stays
 * inert outside an iframe — so we leave it on by default in production.
 */
import { VisualEditing } from "@sanity/astro/visual-editing";

const enabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED !== "false";
---

<VisualEditing client:only="react" enabled={enabled} zIndex={1000} />
