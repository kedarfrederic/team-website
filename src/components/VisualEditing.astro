---
/**
 * Sanity Visual Editing overlay — uses the canonical Astro component from
 * `@sanity/astro/visual-editing`. That component is itself an .astro file
 * (NOT a React component) which internally mounts a React child with
 * `client:only="react"` — so we just render it like any other Astro
 * component. Adding our own `client:` directive breaks it (the Astro
 * component definition gets passed to React's renderer, which throws #130).
 *
 * Toggle via the `PUBLIC_SANITY_VISUAL_EDITING_ENABLED` env var:
 *   - "true" or unset → mount the overlay on every request
 *   - "false"          → no overlay code ships
 *
 * The overlay is iframe-aware — even when enabled, it stays inert outside
 * an iframe — so we leave it on by default.
 */
import { VisualEditing } from "@sanity/astro/visual-editing";

const enabled =
  import.meta.env.PUBLIC_SANITY_VISUAL_EDITING_ENABLED !== "false";
---

<VisualEditing enabled={enabled} zIndex={1000} />
