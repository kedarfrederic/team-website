---
/**
 * Integrations marquee. DOM IDs (techRow1, techRow2, integrationsMarquees,
 * data-module="marquee") preserved verbatim — the legacy inline JS in
 * /components/homepage-inline-1.js drives the infinite scroll based on
 * those identifiers.
 *
 * Headline + subhead + every logo are bound to homepage.integrationsMarquee.
 * Each logo can be either an uploaded Sanity image or an external URL —
 * marketing can swap any logo, reorder, add new ones, or remove placeholders.
 */
import { urlFor } from "../../lib/sanity";

interface Logo {
  name?: string;
  logo?: any;     // Sanity image
  logoUrl?: string;
  title?: string;
}

interface Props {
  data?: {
    headlineTop?: string;
    headlineBottom?: string;
    headline?: string;
    subhead?: string;
    logos?: Logo[];
  };
}

const { data } = Astro.props;
const headlineTop = data?.headlineTop ?? data?.headline ?? "Connects to";
const headlineBottom = data?.headlineBottom ?? "your tech stack";
const subhead = data?.subhead ?? "Works with the tools your team already uses. No migration, no disruption.";

const DEFAULT_LOGOS: Logo[] = [
  { name: "Asana", logoUrl: "https://cdn.simpleicons.org/asana" },
  { name: "Jira", logoUrl: "https://cdn.simpleicons.org/jira" },
  { name: "Trello", logoUrl: "https://cdn.simpleicons.org/trello" },
  { name: "Notion", logoUrl: "https://cdn.simpleicons.org/notion/111111" },
  { name: "ClickUp", logoUrl: "https://cdn.simpleicons.org/clickup" },
  { name: "Linear", logoUrl: "https://cdn.simpleicons.org/linear/5E6AD2" },
  { name: "Monday.com", logoUrl: "https://cdn.jsdelivr.net/gh/gilbarbara/logos@main/logos/monday.svg" },
  { name: "Confluence", logoUrl: "https://cdn.simpleicons.org/confluence" },
  { name: "Slack", logoUrl: "https://svgl.app/library/slack.svg" },
  { name: "Microsoft Teams", logoUrl: "https://svgl.app/library/microsoft-teams.svg" },
  { name: "Discord", logoUrl: "https://cdn.simpleicons.org/discord" },
  { name: "Zoom", logoUrl: "https://cdn.simpleicons.org/zoom" },
  { name: "Gmail", logoUrl: "https://cdn.simpleicons.org/gmail" },
  { name: "Outlook", logoUrl: "https://svgl.app/library/microsoft-outlook.svg" },
  { name: "Google Drive", logoUrl: "https://cdn.simpleicons.org/googledrive" },
  { name: "Dropbox", logoUrl: "https://cdn.simpleicons.org/dropbox" },
  { name: "OneDrive", logoUrl: "https://svgl.app/library/microsoft-onedrive.svg" },
  { name: "Word", logoUrl: "https://svgl.app/library/microsoft-word.svg" },
  { name: "Excel", logoUrl: "https://svgl.app/library/microsoft-excel.svg" },
  { name: "PowerPoint", logoUrl: "https://svgl.app/library/microsoft-powerpoint.svg" },
  { name: "Figma", logoUrl: "https://cdn.simpleicons.org/figma" },
];

const sourceLogos: Logo[] = (Array.isArray(data?.logos) && data.logos.length > 0) ? data.logos : DEFAULT_LOGOS;

interface ResolvedLogo { name: string; src: string; title?: string }
const ROW_1: ResolvedLogo[] = sourceLogos.map((l) => {
  const src = l.logo?.asset
    ? urlFor(l.logo).height(48).format("webp").url()
    : (l.logoUrl ?? "");
  return { name: l.name ?? "", src, title: l.title };
}).filter((l) => l.src);

// Row 2 starts halfway through the list for visual offset
const half = Math.floor(ROW_1.length / 2);
const ROW_2: ResolvedLogo[] = [...ROW_1.slice(half), ...ROW_1.slice(0, half)];
---

<section class="integrations-section" data-module="marquee">
  <div class="container container--center">
    <div class="section-intro" style="max-width:none">
      <h2 class="headline-lg">{headlineTop} <span class="nyght">{headlineBottom}</span></h2>
      <p class="body-lg">{subhead}</p>
    </div>
  </div>

  <div class="integrations-marquees" id="integrationsMarquees">
    <div class="tech-row-wrap">
      <div class="tech-row" id="techRow1">
        {[...ROW_1, ...ROW_1].map((logo, i) => (
          <a class="tech-logo" title={i < ROW_1.length ? (logo.title ?? logo.name) : undefined}>
            <img src={logo.src} alt={i < ROW_1.length ? logo.name : ""} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </div>
    <div class="tech-row-wrap">
      <div class="tech-row" id="techRow2">
        {[...ROW_2, ...ROW_2].map((logo, i) => (
          <a class="tech-logo" title={i < ROW_2.length ? (logo.title ?? logo.name) : undefined}>
            <img src={logo.src} alt={i < ROW_2.length ? logo.name : ""} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
