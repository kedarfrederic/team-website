---
/**
 * "From independent artists to major labels" 4-tab section. Each tab has
 * a featured item (#01 — title + description) + up to 3 stack rows + a
 * learn-more link.
 *
 * Schema: homepage.rolesTabs (label + featuredHeading + featuredBody +
 * stackRows + learnMoreLabel + learnMoreHref).
 *
 * Inline JS handles tab switching and reads `data-role` attributes — we
 * preserve those keys exactly to keep the legacy interaction working.
 */

interface StackRow { number?: string; title?: string; description?: string }
interface RolesTab {
  label: string;
  roleKey?: string;
  featuredHeading?: string;
  featuredBody?: string;
  stackRows?: StackRow[];
  learnMoreLabel?: string;
  learnMoreHref?: string;
}

interface Props {
  data?: {
    label?: string;
    headline?: string;
    headlineSuffixA?: string;
    headlineSuffixB?: string;
    subhead?: string;
    tabs?: RolesTab[];
  };
}

// Fallback content matches the legacy homepage section.
const FALLBACK_TABS: (RolesTab & { roleKey: string })[] = [
  {
    roleKey: "artist",
    label: "Artists",
    featuredHeading: "Run your own rollout",
    featuredBody: "Plan your release, keep collaborators aligned, and stay on top of every deadline — without needing a label behind you.",
    stackRows: [
      { number: "02", title: "Creative asset hub", description: "Keep artwork, videos, masters, and promo assets in one place for every release." },
      { number: "03", title: "Fan engagement playbook", description: "Schedule socials, pre-saves, and fan moments connected to your timeline." },
      { number: "04", title: "Collaborator coordination", description: "Bring producers, managers, and PR into a shared workspace — no Slack chaos." },
    ],
    learnMoreLabel: "Learn more about Team for Artists",
    learnMoreHref: "/for-artists",
  },
  {
    roleKey: "manager",
    label: "Managers",
    featuredHeading: "One view across every artist",
    featuredBody: "Timeline, budget, assets, comms — everything you need to run multiple artists' releases side by side.",
    stackRows: [
      { number: "02", title: "Stakeholder updates in one click", description: "Generate status reports for artists, labels, and partners automatically." },
      { number: "03", title: "Deadline tracking", description: "Smart notifications before pitches, assets, or approvals are late." },
      { number: "04", title: "Cross-functional coordination", description: "Keep PR, social, paid, and distribution aligned without being the human glue." },
    ],
    learnMoreLabel: "Learn more about Team for Managers",
    learnMoreHref: "/for-managers",
  },
  {
    roleKey: "label",
    label: "Labels",
    featuredHeading: "Cross-roster visibility",
    featuredBody: "See every release across every artist in one view. Know what's on track, what's at risk, and where to focus today.",
    stackRows: [
      { number: "02", title: "Budget oversight", description: "Track spend across releases and artists in real time. No more end-of-quarter surprises." },
      { number: "03", title: "Team performance", description: "Understand who's delivering, what's bottlenecking — with data, not gut feel." },
      { number: "04", title: "Strategic planning", description: "Map your release calendar against market windows, competitor drops, and cultural moments." },
    ],
    learnMoreLabel: "Learn more about Team for Labels",
    learnMoreHref: "/for-labels",
  },
  {
    roleKey: "marketing",
    label: "Marketing & A&R",
    featuredHeading: "Campaign planning that sticks",
    featuredBody: "Build multi-channel marketing plans connected to your release timeline. Social, paid, email — all in sync.",
    stackRows: [
      { number: "02", title: "Content production", description: "Brief, draft, review, and approve assets without leaving the platform. TeamMate handles first drafts." },
      { number: "03", title: "Release readiness", description: "Know where every release stands — masters delivered, metadata confirmed, artwork approved." },
      { number: "04", title: "Playlist & press strategy", description: "Track pitch windows, submission deadlines, and editorial contacts. Never miss an opportunity." },
    ],
    learnMoreLabel: "Learn more about Team for Partners",
    learnMoreHref: "/for-partners",
  },
];

const { data } = Astro.props;
const label = data?.label ?? "Built for every role";
const headlineA = "From";
const headlineB = data?.headlineSuffixA ?? "independent artists";
const headlineC = "to";
const headlineD = data?.headlineSuffixB ?? "major labels";
const subhead = data?.subhead ?? "Whether you manage one artist or a roster of fifty, Team adapts to how you work.";

// Map data tabs → render-ready shape; fall back to legacy fixtures.
const tabs: (RolesTab & { roleKey: string })[] =
  Array.isArray(data?.tabs) && data.tabs.length > 0
    ? data.tabs.map((t, i) => ({
        ...t,
        roleKey: t.roleKey ?? FALLBACK_TABS[i]?.roleKey ?? `tab${i + 1}`,
      }))
    : FALLBACK_TABS;
---

<section class="roles-section" id="rolesSection">
  <div class="roles-inner">
    <div class="roles-header">
      <div class="roles-label">{label}</div>
      <h2 class="headline-lg">
        {headlineA} <span class="nyght">{headlineB}</span><br />
        {headlineC} <span class="nyght">{headlineD}</span>
      </h2>
      <p class="body-lg" style="max-width:36rem;margin:1rem auto 0;color:var(--text-secondary)">{subhead}</p>
    </div>

    <div class="roles-tabs" role="tablist">
      {tabs.map((tab, i) => (
        <button
          class={`roles-tab ${i === 0 ? "is-active" : ""}`}
          data-role={tab.roleKey}
          role="tab"
        >
          {tab.label}
        </button>
      ))}
    </div>

    <div class="roles-panels">
      {tabs.map((tab, i) => (
        <div class={`roles-panel ${i === 0 ? "is-active" : ""}`} data-role={tab.roleKey}>
          <div class="role-featured">
            <div class="role-featured__num">01</div>
            <div class="role-featured__title">{tab.featuredHeading}</div>
            <div class="role-featured__desc">{tab.featuredBody}</div>
          </div>
          <div class="role-stack">
            {(tab.stackRows ?? []).map((row) => (
              <div class="role-row">
                <div class="role-row__num">{row.number}</div>
                <div>
                  <div class="role-row__title">{row.title}</div>
                  <div class="role-row__desc">{row.description}</div>
                </div>
              </div>
            ))}
          </div>
          {tab.learnMoreHref && tab.learnMoreLabel && (
            <a href={tab.learnMoreHref} class="role-learn-more" style="grid-column:1/-1;text-align:center">
              <span class="rlm-text">{tab.learnMoreLabel}</span> <span class="arrow">→</span>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
