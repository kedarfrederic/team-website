---
import BaseLayout from "../layouts/BaseLayout.astro";
import IcpPage from "../components/pages/IcpPage.astro";
import { getIcpPage } from "../lib/queries";
import { getClient } from "../lib/sanity";

const page = await getIcpPage("forManagersPage", getClient(Astro));
---

<BaseLayout
  title={page?.hero?.headlineTop ?? page?.hero?.headline ?? "For Managers"}
  description={page?.hero?.subhead ?? "Every artist. Every release. One dashboard."}
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/for-managers-inline.css" />

  <IcpPage page={page} icpKey="managers" />

  <script is:inline src="/components/for-managers-inline.js"></script>
</BaseLayout>
