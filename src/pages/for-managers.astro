---
import BaseLayout from "../layouts/BaseLayout.astro";
import IcpPageContent from "../components/pages/IcpPageContent.astro";
import { getIcpPage } from "../lib/queries";

const page = await getIcpPage("forManagersPage");
const hasHeroBg = !!page?.hero?.backgroundImage?.asset?._ref;
---

<BaseLayout
  title={page?.hero?.headline ?? "For Managers"}
  description="Every artist. Every release. One dashboard."
  seo={page?.seo}
  navTheme={hasHeroBg ? "dark" : "light"}
>
  <IcpPageContent page={page} fallbackTitle="For Managers" />
</BaseLayout>
