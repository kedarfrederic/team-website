---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getIcpPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/for-managers-body.html?raw";

const page = await getIcpPage("forManagersPage");
---

<BaseLayout
  title={page?.hero?.headline ?? "For Managers"}
  description="Every artist. Every release. One dashboard."
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/for-managers-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/for-managers-inline.js"></script>
</BaseLayout>
