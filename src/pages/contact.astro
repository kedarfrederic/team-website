---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getContactPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/contact-body.html?raw";

const page = await getContactPage();
---

<BaseLayout
  title={page?.headline ?? "Get in touch"}
  description={page?.subhead ?? "Have a question, want to learn more, or just want to say hello? We'd love to hear from you."}
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/contact-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/contact-inline.js"></script>
</BaseLayout>
