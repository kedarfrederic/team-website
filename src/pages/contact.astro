---
import BaseLayout from "../layouts/BaseLayout.astro";
import Wordmark from "../components/Wordmark.astro";
import { getContactPage } from "../lib/queries";
import { getClient, urlFor } from "../lib/sanity";

const page = await getContactPage(getClient(Astro));

// ── Fallback copy keeps the page identical when the doc is empty ─────
const headline = page?.headline ?? "Get in touch";
const subhead =
  page?.subhead ??
  "Have a question, want to learn more, or just want to say hello?\nWe'd love to hear from you.";
const submitLabel = page?.submitLabel ?? "Send message";
const emailFallbackText =
  page?.emailFallbackText ?? "Or email us directly at";
const bgUrl = page?.backgroundImage?.asset
  ? urlFor(page.backgroundImage).width(2400).quality(85).format("webp").url()
  : "/assets/hero-bg-option-1.jpeg";

interface InterestOption {
  label: string;
  value: string;
}

const interestOptions: InterestOption[] =
  Array.isArray(page?.interestOptions) && page.interestOptions.length > 0
    ? page.interestOptions
    : [
        { label: "Team for Artists", value: "artists" },
        { label: "Team for Managers", value: "managers" },
        { label: "Team for Labels", value: "labels" },
        { label: "Team for Enterprise", value: "enterprise" },
      ];

// Per-input copy. Fallbacks keep the page identical when the formCopy
// block hasn't been authored. Editing in Studio overrides per-field.
const fc = page?.formCopy ?? {};
const firstNameLabel       = fc.firstName?.label         ?? "First name";
const firstNamePlaceholder = fc.firstName?.placeholder   ?? "Jane";
const lastNameLabel        = fc.lastName?.label          ?? "Last name";
const lastNamePlaceholder  = fc.lastName?.placeholder    ?? "Doe";
const emailLabel           = fc.email?.label             ?? "Email address";
const emailPlaceholder     = fc.email?.placeholder       ?? "you@yourlabel.com";
const orgLabel             = fc.organization?.label      ?? "Organization / Label name";
const orgPlaceholder       = fc.organization?.placeholder ?? "Your label, company, or team name";
const interestGroupLabel   = fc.interest?.label          ?? "I'm interested in";
const messageLabel         = fc.message?.label           ?? "Message";
const messagePlaceholder   = fc.message?.placeholder     ?? "Tell us what you're looking for...";
---

<BaseLayout
  title={headline}
  description={subhead.replace(/\n/g, " ")}
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/contact-inline.css" />

  <div class="contact-bg">
    <img src={bgUrl} alt="" loading="eager" />
  </div>

  <div class="auth-page">
    <div class="auth-header">
      <h1>{headline}</h1>
      <p set:html={subhead.replace(/\n/g, "<br>")} />
    </div>

    <form class="auth-card" id="contactForm" action="#" method="POST" data-hubspot-form="contact">
      <div class="form-row">
        <div class="form-group">
          <label for="firstName">{firstNameLabel}</label>
          <input type="text" id="firstName" name="first_name" placeholder={firstNamePlaceholder} required />
        </div>
        <div class="form-group">
          <label for="lastName">{lastNameLabel}</label>
          <input type="text" id="lastName" name="last_name" placeholder={lastNamePlaceholder} required />
        </div>
      </div>

      <div class="form-group">
        <label for="email">{emailLabel}</label>
        <input type="email" id="email" name="email" placeholder={emailPlaceholder} required />
      </div>

      <div class="form-group">
        <label for="orgName">{orgLabel}</label>
        <input type="text" id="orgName" name="organization" placeholder={orgPlaceholder} />
      </div>

      <div class="interest-group">
        <label class="interest-label">{interestGroupLabel}</label>
        <div class="interest-options">
          {interestOptions.map((opt) => (
            <label class="interest-option">
              <input type="checkbox" name="interest" value={opt.value} />
              <span>{opt.label}</span>
            </label>
          ))}
        </div>
      </div>

      <div class="form-group">
        <label for="message">{messageLabel}</label>
        <textarea id="message" name="message" rows="4" placeholder={messagePlaceholder}></textarea>
      </div>

      <button type="submit" class="btn-submit" id="submitBtn">{submitLabel}</button>
      <p class="auth-email">{emailFallbackText} <a href="mailto:hello@teamrollouts.com">hello@teamrollouts.com</a></p>
    </form>

    <Wordmark href="/" />
  </div>

  <script is:inline src="/components/contact-inline.js"></script>
</BaseLayout>
