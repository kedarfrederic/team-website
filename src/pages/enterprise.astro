---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEnterprisePage } from "../lib/queries";
import { getClient } from "../lib/sanity";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/enterprise-body.html?raw";

const page = await getEnterprisePage(getClient(Astro));
---

<BaseLayout
  title={page?.hero?.headline ?? "Enterprise"}
  description="Scale without compromise. Security without sacrifice."
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/enterprise-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/enterprise-inline.js"></script>
</BaseLayout>
