---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVerticalProductPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/intelligence-body.html?raw";

const page = await getVerticalProductPage("intelligencePage");
---

<BaseLayout
  title={page?.hero?.headline ?? "Intelligence"}
  description="The smartest person in the room."
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/intelligence-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/intelligence-inline.js"></script>
</BaseLayout>
