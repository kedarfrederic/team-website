---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPartnerPage } from "../lib/queries";
import { getClient } from "../lib/sanity";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/for-partners-body.html?raw";

const page = await getPartnerPage(getClient(Astro));
const hero = page?.hero;
---

<BaseLayout
  title={hero?.headline ?? "For Partners"}
  description="Your clients are already on Team. Now you can be too."
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/for-partners-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/for-partners-inline.js"></script>
</BaseLayout>
