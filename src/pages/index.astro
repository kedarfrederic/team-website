---
/**
 * Homepage — Phase 5.2 visual port.
 *
 * Strategy: the legacy homepage.html has ~1850 lines of unique inline CSS,
 * ~1400 lines of body HTML with intricate scroll-pinned sections, and
 * ~1400 lines of inline JS for animations (typewriter, scroll-pin tiles,
 * role tabs, search demo, releases→timeline transition, marquee, swiper,
 * stories carousel). Rather than transcribing all of that into Astro
 * components (lossy + slow + error-prone), we:
 *
 *   1. Extract the inline CSS to public/components/homepage-inline.css
 *   2. Extract the inline JS to public/components/homepage-inline-{1,2}.js
 *   3. Extract the body HTML to src/lib/homepage-body.html
 *   4. Import the body as a raw string at build time and inject via set:html
 *   5. Reference the CSS and JS files in <head> + before </body>
 *
 * Result: visually identical to the legacy site, every interaction works,
 * and we keep the Sanity-driven structure available to layer in later
 * (the BaseLayout still owns nav/footer/SEO and accepts navTheme).
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { getHomepage } from "../lib/queries";
import { getClient } from "../lib/sanity";
// @ts-expect-error — Astro's ?raw modifier returns a string at build time
import bodyHtml from "../lib/homepage-body.html?raw";

const page = await getHomepage(getClient(Astro));
const hero = page?.hero;
const heroBg = !!hero?.backgroundImage?.asset?._ref;
---

<BaseLayout
  title={hero?.headline ?? "Team — The Operating System for Music Releases"}
  description="Stop juggling spreadsheets, Slack threads, and email chains. One platform for your entire rollout."
  seo={page?.seo}
  navTheme={heroBg ? "dark" : "light"}
>
  {/* Page-specific stylesheets — order matters: team-home (base) → homepage (component) → inline (page-specific overrides) */}
  <link slot="head" rel="stylesheet" href="/components/team-home.css" />
  <link slot="head" rel="stylesheet" href="/components/homepage.css" />
  <link slot="head" rel="stylesheet" href="/components/homepage-inline.css" />

  {/* External libs the legacy JS depends on */}
  <link slot="head" rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />

  {/* Body content from legacy homepage.html — injected as-is at build time */}
  <Fragment set:html={bodyHtml} />

  {/* External libs for animations */}
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/Flip.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/Observer.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/Draggable.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3/dist/CustomEase.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/lenis@1/dist/lenis.min.js"></script>
  <script is:inline src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

  {/*
    Page-specific JS — must run after libs above.

    Deliberately NOT loading /components/homepage.js: it duplicates the
    inline JS, and legacy homepage.html only loaded the inline block.
    Loading both spins up two Lenis smooth-scroll instances and
    double-binds ScrollTriggers, which breaks the scroll-pinned hero
    tiles and lets the testimonial swiper render unconstrained.
  */}
  <script is:inline src="/components/homepage-inline-1.js"></script>
  <script is:inline src="/components/homepage-inline-2.js"></script>
</BaseLayout>
