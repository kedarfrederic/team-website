---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAboutPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/about-body.html?raw";

const page = await getAboutPage();
---

<BaseLayout
  title={page?.hero?.headline ?? "About"}
  description="Built by people who ship music for a living."
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/about-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/about-inline.js"></script>
</BaseLayout>
