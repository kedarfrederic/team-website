---
import BaseLayout from "../layouts/BaseLayout.astro";
import SplitHeadline from "../components/SplitHeadline.astro";
import PortableText from "../components/PortableText.astro";
import { getAboutPage } from "../lib/queries";
import { getClient, urlFor } from "../lib/sanity";

/**
 * About — first fully Sanity-driven page (the canonical Phase 6 reference).
 *
 * Every visible string, the hero background, every value card, every roles
 * link, the contact CTA — all read from the `aboutPage` singleton. When the
 * doc is empty (fresh project) we fall back to the original copy so the
 * page never renders blank during the migration.
 *
 * Inline JS / CSS at /components/about-inline.* is preserved verbatim — it
 * binds to `#heroSection` and `.value-card` which we keep below.
 */

const page = await getAboutPage(getClient(Astro));

const hero = page?.hero ?? {};
const mission = page?.mission ?? {};
const story = page?.story ?? {};
const valuesSection = page?.valuesSection ?? {};
const contactCta = page?.contactCta ?? {};
const rolesGrid = page?.rolesGrid ?? {};

// ── Fallback copy — keeps the page visually identical when the Sanity doc
//    hasn't been populated yet.
const heroPill = hero.pillLabel ?? "About";
const heroTop = hero.headlineTop ?? "Built by people who";
const heroBottom = hero.headlineBottom ?? "ship music for a living";
const heroSubhead =
  hero.subhead ??
  "Team was founded by people who've lived the chaos of release management firsthand — and decided to fix it.";
const heroBgUrl = hero.backgroundImage?.asset
  ? urlFor(hero.backgroundImage).width(2400).quality(85).format("webp").url()
  : "/assets/hero-bg-new.png";

const missionTop = mission.headlineTop ?? "The operating system";
const missionBottom = mission.headlineBottom ?? "for music releases";
const missionFallback = [
  "Every day, thousands of releases ship across every platform, every genre, every market. Behind each one is a team of people coordinating timelines, chasing assets, managing budgets, and hoping nothing falls through the cracks.",
  "We built Team because we believe that process shouldn't be held together by spreadsheets, group chats, and calendar reminders. Music deserves its own operating system — one that understands releases, not just projects.",
];

const storyTop = story.headlineTop ?? "Why we";
const storyBottom = story.headlineBottom ?? "started Team";
const storyFallback = [
  "We've been on both sides of the release. As artists trying to get music out. As managers juggling rosters. As label teams coordinating across departments. And every time, the same problem: the tools weren't built for this.",
  "Project management tools are great for software teams. CRMs are great for sales teams. But nobody had built something specifically for the people who ship music. So we did.",
  "Team combines release orchestration with AI-powered intelligence to give every artist, manager, and label a structured, visible, and intelligent way to run their releases — from first demo to post-release analysis.",
];

const valuesTop = valuesSection.headlineTop ?? "What drives";
const valuesBottom = valuesSection.headlineBottom ?? "how we build";
const values =
  Array.isArray(valuesSection.values) && valuesSection.values.length > 0
    ? valuesSection.values
    : [
        { title: "Music first", body: "Every feature starts with a release. We don't build generic tools and bolt on music features. We start with the way music actually ships and work backwards from there." },
        { title: "AI as an enabler", body: "We use AI to make people better at what they do — not to replace them. Every recommendation, every insight, every suggestion is there to inform your decisions, not make them for you." },
        { title: "Your data, your rules", body: "Your releases, your strategy, your audience data — it's yours. We don't train our models on your data, we don't share it across accounts, and we never will." },
      ];

const ctaTop = contactCta.headlineTop ?? "Want to";
const ctaBottom = contactCta.headlineBottom ?? "get in touch?";
const ctaBody =
  contactCta.body ??
  "Whether you want to learn more about Team, explore a partnership, or just say hello — we'd love to hear from you. Our founders answer every message personally.";
const ctaLabel = contactCta.linkLabel ?? "Contact us";
const ctaHref = contactCta.linkHref ?? "/contact";

const rolesTop = rolesGrid.headlineTop ?? rolesGrid.eyebrow ?? "Designed for";
const rolesBottom = rolesGrid.headlineBottom ?? rolesGrid.headline ?? "how you work";
const rolesCards =
  Array.isArray(rolesGrid.cards) && rolesGrid.cards.length > 0
    ? rolesGrid.cards
    : [
        { title: "For Artists", description: "Your release, structured. No more winging it.", href: "/for-artists" },
        { title: "For Managers", description: "Every artist's rollout. One dashboard.", href: "/for-managers" },
        { title: "For Labels", description: "Scale your release process. Not your headcount.", href: "/for-labels" },
        { title: "For Partners", description: "See your deliverables. Hit your deadlines.", href: "/for-partners" },
      ];
---

<BaseLayout
  title={hero.headlineTop ?? "About"}
  description={heroSubhead}
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/about-inline.css" />

  <section class="icp-hero" id="heroSection">
    <div class="icp-hero__bg"><img src={heroBgUrl} alt="" loading="eager" /></div>
    <div class="icp-hero__overlay"></div>
    <div class="icp-hero__inner">
      <span class="hero-pill">{heroPill}</span>
      <SplitHeadline as="h1" top={heroTop} bottom={heroBottom} />
      <p>{heroSubhead}</p>
    </div>
  </section>

  <section class="about-mission">
    <div class="about-mission__inner">
      <SplitHeadline as="h2" top={missionTop} bottom={missionBottom} />
      <div class="about-mission__copy">
        {Array.isArray(mission.body) && mission.body.length > 0
          ? <PortableText value={mission.body} />
          : missionFallback.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <section class="about-story">
    <div class="about-story__inner">
      <div class="about-story__headline">
        <SplitHeadline as="h2" top={storyTop} bottom={storyBottom} />
      </div>
      <div class="about-story__copy">
        {Array.isArray(story.body) && story.body.length > 0
          ? <PortableText value={story.body} />
          : storyFallback.map((p) => <p>{p}</p>)}
      </div>
    </div>
  </section>

  <section class="about-values">
    <div class="about-values__inner">
      <div class="about-values__header">
        <SplitHeadline as="h2" top={valuesTop} bottom={valuesBottom} />
      </div>
      <div class="values-grid">
        {values.map((v: { title: string; body: string }) => (
          <div class="value-card">
            <div class="value-card__accent"></div>
            <h3>{v.title}</h3>
            <p>{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="about-cta">
    <div class="about-cta__inner">
      <div class="about-cta__headline">
        <SplitHeadline as="h2" top={ctaTop} bottom={ctaBottom} />
      </div>
      <div class="about-cta__copy">
        <p>{ctaBody}</p>
        <a href={ctaHref} class="about-cta__link">
          <span class="about-link-text">{ctaLabel}</span>
          <svg viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
        </a>
      </div>
    </div>
  </section>

  <section class="roles-section">
    <div class="roles-section__inner">
      <div class="roles-section__header">
        <SplitHeadline as="h2" top={rolesTop} bottom={rolesBottom} />
      </div>
      <div class="roles-grid">
        {rolesCards.map((card: { title: string; description: string; href: string }, i: number) => (
          <>
            {i > 0 && <div class="roles-divider"></div>}
            <a href={card.href} class="role-item">
              <div class="role-item__title">{card.title}</div>
              <div class="role-item__desc">{card.description}</div>
              <div class="role-item__link">
                Learn more <svg viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
              </div>
            </a>
          </>
        ))}
      </div>
    </div>
  </section>

  <script is:inline src="/components/about-inline.js"></script>
</BaseLayout>
