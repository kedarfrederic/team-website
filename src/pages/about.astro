---
/**
 * /about — first migrated page, validates the full block-component pipeline.
 *
 * Uses the Phase 3 components (PortableText, CtaBlock, RolesGrid) so the
 * page is the canonical reference for how subsequent pages compose blocks.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import PortableText from "../components/PortableText.astro";
import CtaBlock from "../components/blocks/CtaBlock.astro";
import RolesGrid from "../components/blocks/RolesGrid.astro";
import { getAboutPage } from "../lib/queries";

const page = await getAboutPage();
const hero = page?.hero;
const mission = page?.mission;
const story = page?.story;
const values = page?.valuesSection;
---

<BaseLayout
  title="About"
  description="Built by people who ship music for a living."
  seo={page?.seo}
>
  {/* Hero */}
  <section class="about-hero">
    <div class="container container--center">
      {hero?.pillLabel && <span class="label-sm pill">{hero.pillLabel}</span>}
      <h1 class="headline-xl">{hero?.headline ?? "About Team"}</h1>
      {hero?.subhead && <p class="body-lg">{hero.subhead}</p>}
    </div>
  </section>

  {/* Mission */}
  {mission && (
    <section class="about-mission">
      <div class="container">
        {mission.headline && <h2 class="headline-lg">{mission.headline}</h2>}
        {mission.body && <PortableText value={mission.body} />}
      </div>
    </section>
  )}

  {/* Story */}
  {story && (
    <section class="about-story">
      <div class="container">
        {story.headline && <h2 class="headline-lg">{story.headline}</h2>}
        {story.body && <PortableText value={story.body} />}
      </div>
    </section>
  )}

  {/* Values */}
  {values?.values && values.values.length > 0 && (
    <section class="about-values">
      <div class="container">
        {values.headline && <h2 class="headline-lg">{values.headline}</h2>}
        <div class="values-grid">
          {values.values.map((v: any) => (
            <article class="value-card">
              <h3>{v.title}</h3>
              <p>{v.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Roles grid (cross-link) — uses Phase 3 component */}
  <RolesGrid value={page?.rolesGrid} />

  {/* Final CTA — uses Phase 3 component */}
  <CtaBlock value={page?.finalCta} />

  {/* Empty-state hint shown when no content has been authored yet */}
  {!page && (
    <section class="empty-state">
      <div class="container container--center">
        <p class="body-lg">
          This page hasn't been authored in Sanity yet. Open the Studio at
          <code>/sanity</code> and create the <strong>About</strong> document.
        </p>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .about-hero,
  .about-mission,
  .about-story,
  .about-values,
  .empty-state {
    padding: 6rem 0;
  }
  .pill {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--grey);
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .about-mission .headline-lg,
  .about-story .headline-lg,
  .about-values .headline-lg {
    margin-bottom: 1.5rem;
    max-width: 36rem;
  }
  .values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }
  .value-card {
    padding: 1.5rem;
  }
  .value-card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }
  .value-card p {
    color: var(--text-secondary);
    line-height: 1.6;
  }
  .empty-state code {
    background: var(--bg);
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-family: ui-monospace, monospace;
  }
</style>
