---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPricingPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/pricing-body.html?raw";

const page = await getPricingPage();
---

<BaseLayout
  title={page?.hero?.headline ?? "Pricing"}
  description="Start free. Upgrade when you're ready."
  seo={page?.seo}
>
  <link slot="head" rel="stylesheet" href="/components/pricing-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/pricing-inline.js"></script>
</BaseLayout>
