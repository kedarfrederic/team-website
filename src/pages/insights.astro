---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getInsightsIndexPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/insights-body.html?raw";

const page = await getInsightsIndexPage();
---

<BaseLayout
  title={page?.hero?.headline ?? "Insights"}
  description="Strategy, product, and industry takes from the Team."
  seo={page?.seo}
>
  <link slot="head" rel="stylesheet" href="/components/insights-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/insights-inline.js"></script>
</BaseLayout>
