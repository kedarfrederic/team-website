---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVerticalProductPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/orchestration-body.html?raw";

const page = await getVerticalProductPage("orchestrationPage");
---

<BaseLayout
  title={page?.hero?.headline ?? "Orchestration"}
  description="No more square pegs, round holes."
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/orchestration-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/orchestration-inline.js"></script>
</BaseLayout>
