---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getIntegrationsPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/integrations-body.html?raw";

const page = await getIntegrationsPage();
---

<BaseLayout
  title={page?.hero?.headline ?? "Integrations"}
  description="Connect Team to the tools you already use."
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/integrations-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/integrations-inline.js"></script>
</BaseLayout>
