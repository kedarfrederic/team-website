---
import BaseLayout from "../layouts/BaseLayout.astro";
import RolesGrid from "../components/blocks/RolesGrid.astro";
import CtaBlock from "../components/blocks/CtaBlock.astro";
import { getIntegrationsPage, getIntegrations } from "../lib/queries";
import { urlFor } from "../lib/sanity";

const [page, integrations] = await Promise.all([getIntegrationsPage(), getIntegrations()]);
const hero = page?.hero;
const grid = page?.gridSection;
const api = page?.apiSection;

// Group by category for the filter UI
const CATEGORY_LABELS: Record<string, string> = {
  distribution: "Distribution",
  social: "Social",
  analytics: "Analytics",
  productivity: "Productivity",
};
---

<BaseLayout
  title={hero?.headline ?? "Integrations"}
  description="Connect Team to the tools you already use."
  seo={page?.seo}
>
  {/* Hero */}
  <section class="integrations-hero">
    <div class="container container--center">
      {hero?.pillLabel && <span class="label-sm pill">{hero.pillLabel}</span>}
      <h1 class="headline-xl">{hero?.headline ?? "Integrations"}</h1>
      {hero?.subhead && <p class="body-lg">{hero.subhead}</p>}
    </div>
  </section>

  {/* Grid section */}
  <section class="integrations-grid-section">
    <div class="container">
      {grid?.headline && <h2 class="headline-lg">{grid.headline}</h2>}
      {grid?.subhead && <p class="body-lg">{grid.subhead}</p>}

      <div class="integrations-toolbar">
        <input
          type="search"
          id="integrations-search"
          placeholder={grid?.searchPlaceholder ?? "Search integrations…"}
          class="integrations-search"
        />
        <div class="integrations-filters" role="tablist">
          <button class="filter-btn is-active" data-filter="all">All</button>
          {Object.entries(CATEGORY_LABELS).map(([value, label]) => (
            <button class="filter-btn" data-filter={value}>{label}</button>
          ))}
        </div>
      </div>

      {integrations && integrations.length > 0 ? (
        <ul class="integrations-grid" id="integrations-grid">
          {integrations.map((i: any) => (
            <li
              class="integration-card"
              data-name={i.name?.toLowerCase()}
              data-category={i.category}
              data-coming-soon={i.comingSoon ? "true" : "false"}
            >
              {i.comingSoon ? (
                <article class="integration-card__inner">
                  {i.logo && <img src={urlFor(i.logo).width(80).format("webp").url()} alt={i.name} class="integration-card__logo" />}
                  <h3>{i.name}</h3>
                  <p>{i.description}</p>
                  <span class="integration-card__badge">Coming Soon</span>
                </article>
              ) : (
                <a href={i.href ?? "#"} class="integration-card__inner">
                  {i.logo && <img src={urlFor(i.logo).width(80).format("webp").url()} alt={i.name} class="integration-card__logo" />}
                  <h3>{i.name}</h3>
                  <p>{i.description}</p>
                </a>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <p class="empty-state">No integrations have been added yet.</p>
      )}
    </div>
  </section>

  {/* API section */}
  {api && (
    <section class="integrations-api">
      <div class="container container--center">
        {api.headline && <h2 class="headline-lg">{api.headline}</h2>}
        {api.body && <p class="body-lg">{api.body}</p>}
        {api.ctaLabel && api.ctaHref && (
          <a href={api.ctaHref} class="btn btn--outline">{api.ctaLabel}</a>
        )}
      </div>
    </section>
  )}

  <RolesGrid value={page?.rolesGrid} />
  <CtaBlock value={page?.finalCta} />
</BaseLayout>

<script>
  const grid = document.getElementById("integrations-grid");
  const search = document.getElementById("integrations-search") as HTMLInputElement | null;
  const filterButtons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
  let activeFilter = "all";
  let activeQuery = "";

  function applyFilters() {
    if (!grid) return;
    const cards = grid.querySelectorAll<HTMLElement>(".integration-card");
    cards.forEach((card) => {
      const name = card.dataset.name ?? "";
      const cat = card.dataset.category ?? "";
      const matchesQuery = activeQuery === "" || name.includes(activeQuery);
      const matchesFilter = activeFilter === "all" || cat === activeFilter;
      card.style.display = matchesQuery && matchesFilter ? "" : "none";
    });
  }

  filterButtons.forEach((btn) => {
    btn.addEventListener("click", () => {
      filterButtons.forEach((b) => b.classList.remove("is-active"));
      btn.classList.add("is-active");
      activeFilter = btn.dataset.filter ?? "all";
      applyFilters();
    });
  });

  search?.addEventListener("input", () => {
    activeQuery = (search.value ?? "").trim().toLowerCase();
    applyFilters();
  });
</script>

<style>
  .integrations-hero,
  .integrations-grid-section,
  .integrations-api {
    padding: 6rem 0;
  }
  .pill {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border: 1px solid var(--grey);
    border-radius: 999px;
    margin-bottom: 1.5rem;
  }
  .integrations-grid-section .headline-lg {
    text-align: center;
    margin-bottom: 0.75rem;
  }
  .integrations-grid-section .body-lg {
    text-align: center;
    max-width: 38rem;
    margin: 0 auto 3rem;
  }
  .integrations-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .integrations-search {
    flex: 1;
    min-width: 200px;
    max-width: 320px;
    padding: 0.625rem 1rem;
    border: 1px solid var(--grey);
    border-radius: 999px;
    font-size: 0.875rem;
  }
  .integrations-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--grey);
    border-radius: 999px;
    font-size: 0.8125rem;
    font-weight: 500;
    background: #fff;
  }
  .filter-btn.is-active {
    background: #111;
    color: #fff;
    border-color: #111;
  }
  .integrations-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }
  .integration-card__inner {
    display: block;
    padding: 1.5rem;
    border: 1px solid var(--grey);
    border-radius: 12px;
    background: #fff;
    transition: border-color 0.2s, transform 0.2s;
    height: 100%;
  }
  .integration-card[data-coming-soon="false"] .integration-card__inner:hover {
    border-color: #111;
    transform: translateY(-2px);
  }
  .integration-card__logo {
    width: 32px;
    height: 32px;
    object-fit: contain;
    margin-bottom: 1rem;
  }
  .integration-card h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .integration-card p {
    color: var(--text-secondary);
    line-height: 1.5;
    font-size: 0.8125rem;
  }
  .integration-card__badge {
    display: inline-block;
    margin-top: 0.75rem;
    padding: 0.125rem 0.5rem;
    background: var(--bg);
    border-radius: 999px;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .integrations-api .body-lg {
    max-width: 38rem;
    margin: 1rem auto 2rem;
  }
  .empty-state {
    text-align: center;
    color: var(--text-secondary);
  }
</style>
