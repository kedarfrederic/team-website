const FALLBACK: IntegrationDoc[] = [
  { _id: "f1",  name: "Spotify",            description: "Deliver and track releases on the world's largest streaming platform", category: "distribution", logoSrc: "https://cdn.simpleicons.org/spotify/1ED760" },
  { _id: "f2",  name: "Apple Music",        description: "Submit and manage releases across the Apple ecosystem",                  category: "distribution", logoSrc: "https://cdn.simpleicons.org/applemusic/FA243C" },
  { _id: "f3",  name: "Amazon Music",       description: "Reach listeners on Amazon's streaming platform",                          category: "distribution", logoSrc: "https://cdn.simpleicons.org/amazonmusic/40B4E5" },
  { _id: "f4",  name: "YouTube Music",      description: "Distribute music and videos to YouTube's audience",                       category: "distribution", logoSrc: "https://cdn.simpleicons.org/youtubemusic/FF0000" },
  { _id: "f5",  name: "Instagram",          description: "Plan and schedule content aligned to your release timeline",              category: "social",       logoSrc: "https://cdn.simpleicons.org/instagram/E4405F" },
  { _id: "f6",  name: "TikTok",             description: "Coordinate TikTok campaigns with your rollout",                           category: "social",       logoSrc: "https://cdn.simpleicons.org/tiktok/000000" },
  { _id: "f7",  name: "Meta Ads",           description: "Run and track ad campaigns across Facebook and Instagram",                category: "social",       logoSrc: "https://cdn.simpleicons.org/meta/0467DF" },
  { _id: "f8",  name: "X",                  description: "Schedule posts and track engagement around releases",                     category: "social",       logoSrc: "https://cdn.simpleicons.org/x/000000" },
  { _id: "f9",  name: "Spotify for Artists", description: "Pull streaming data directly into your release dashboard",               category: "analytics",    logoSrc: "https://cdn.simpleicons.org/spotify/1ED760" },
  { _id: "f10", name: "Chartmetric",        description: "Track playlist adds, chart positions, and audience growth",               category: "analytics",    logoSrc: "https://cdn.simpleicons.org/chartmogul/FF6900" },
  { _id: "f11", name: "Soundcharts",        description: "Monitor cross-platform performance in real-time",                          category: "analytics",    logoSrc: "https://cdn.simpleicons.org/soundcloud/FF5500" },
  { _id: "f12", name: "Google Analytics",   description: "Track smart link and pre-save campaign performance",                       category: "analytics",    logoSrc: "https://cdn.simpleicons.org/googleanalytics/E37400" },
  { _id: "f13", name: "Slack",              description: "Get release notifications and updates in your team channels",            category: "productivity", logoSrc: "https://svgl.app/library/slack.svg" },
  { _id: "f14", name: "Google Workspace",   description: "Sync calendars, docs, and assets with your release timeline",             category: "productivity", logoSrc: "https://cdn.simpleicons.org/googleworkspace/4285F4" },
  { _id: "f15", name: "Dropbox",            description: "Connect your asset library for seamless file management",                  category: "productivity", logoSrc: "https://cdn.simpleicons.org/dropbox/0061FF" },
  { _id: "f16", name: "Zapier",             description: "Build custom automations between Team and 5,000+ apps",                   category: "productivity", logoSrc: "https://cdn.simpleicons.org/zapier/FF4F00" },
  { _id: "f17", name: "Bandcamp",           description: "Manage Bandcamp releases alongside your DSP strategy",                    category: "distribution", comingSoon: true, logoSrc: "https://cdn.simpleicons.org/bandcamp/408294" },
  { _id: "f18", name: "SoundCloud",         description: "Coordinate SoundCloud uploads with your rollout",                          category: "distribution", comingSoon: true, logoSrc: "https://cdn.simpleicons.org/soundcloud/FF5500" },
  { _id: "f19", name: "Mailchimp",          description: "Sync fan data and automate release email campaigns",                       category: "social",       comingSoon: true, logoSrc: "https://cdn.simpleicons.org/mailchimp/FFE01B" },
  { _id: "f20", name: "HubSpot",            description: "Connect your CRM for deeper fan relationship management",                  category: "social",       comingSoon: true, logoSrc: "https://cdn.simpleicons.org/hubspot/FF7A59" },
];

const cards: IntegrationDoc[] =
  Array.isArray(integrations) && integrations.length > 0 ? integrations : FALLBACK;

// ── Enterprise section (was "build your own integrations") ────
// Reframed for enterprise — labels / distributors / management groups
// who need bespoke connectors into their internal stack.
const api = page?.apiSection ?? {};
const apiTop = api.headlineTop ?? "Need something bespoke?";
const apiBottom = api.headlineBottom ?? "Built for enterprise teams.";
const apiBody =
  api.body ??
  "Major labels, distributors, and management groups often run on internal data warehouses, custom CRMs, and proprietary release tooling. We build dedicated connectors and private endpoints into Team for enterprise customers — including secure SSO, custom data flows, and tailored intelligence pipelines.";
const apiCtaLabel = api.ctaLabel ?? "Talk to us";
const apiCtaHref = api.ctaHref ?? "/contact?interest=enterprise";

// ── Roles cross-link ────────────────────────────────────────
const rolesGrid = page?.rolesGrid ?? {};
const rolesTop = rolesGrid.headlineTop ?? rolesGrid.eyebrow ?? "Designed for";
const rolesBottom = rolesGrid.headlineBottom ?? rolesGrid.headline ?? "how you work";
const rolesCards =
  Array.isArray(rolesGrid.cards) && rolesGrid.cards.length > 0
    ? rolesGrid.cards
    : [
        { title: "For Artists", description: "Your release, structured. No more winging it.", href: "/for-artists" },
        { title: "For Managers", description: "Every artist's rollout. One dashboard.", href: "/for-managers" },
        { title: "For Labels", description: "Scale your release process. Not your headcount.", href: "/for-labels" },
        { title: "For Partners", description: "See your deliverables. Hit your deadlines.", href: "/for-partners" },
      ];
---

<BaseLayout
  title={hero.headlineTop ?? "Integrations"}
  description={heroSubhead}
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/integrations-inline.css" />

  <section class="icp-hero" id="heroSection">
    <div class="icp-hero__bg"><img src={heroBgUrl} alt="" loading="eager" /></div>
    <div class="icp-hero__overlay"></div>
    <div class="icp-hero__inner">
      <span class="hero-pill">{heroPill}</span>
      <SplitHeadline as="h1" top={heroTop} bottom={heroBottom} />
      <p>{heroSubhead}</p>
      <div class="icp-hero__buttons">
        <a href={primaryCta.href} class="btn btn--green">{primaryCta.label}</a>
        <a href={secondaryCta.href} class="btn btn--outline">{secondaryCta.label}</a>
      </div>
    </div>
  </section>

  <section class="int-section" id="intSection">
    <div class="int-section__inner">
      <div class="int-section__header">
        <SplitHeadline as="h2" top={gridTop} bottom={gridBottom} />
        <p>{gridSubhead}</p>
      </div>

      <div class="int-search">
        <svg class="int-search__icon" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" class="int-search__input" id="intSearch" placeholder={searchPlaceholder} />
      </div>

      <div class="int-filters">
        {filters.map((f, i) => (
          <button class={`int-filter ${i === 0 ? "is-active" : ""}`} data-filter={f.filterKey}>{f.label}</button>
        ))}
      </div>

      <div class="int-grid" id="intGrid">
        {cards.map((card) => {
          const isComingSoon = card.comingSoon === true;
          // Cards filed under "coming-soon" data-category to match the legacy filter button.
          const dataCategory = isComingSoon ? "coming-soon" : card.category;
          const cardClass = isComingSoon ? "int-card int-card--soon" : "int-card";
          // Logo source priority:
          //   1. Sanity-uploaded image
          //   2. logoSrc field on the integration doc
          //   3. LOGO_BY_NAME lookup (final fallback for Sanity-seeded
          //      integrations that have no logo / logoSrc — keyed by name)
          //   4. empty (no recognisable mark, just shows blank)
          const sanityLogo = card.logo?.asset
            ? urlFor(card.logo).width(96).format("webp").url()
            : null;
          const fallbackLogo = (card as any).logoSrc as string | undefined;
          const nameLookup = LOGO_BY_NAME[(card.name ?? "").toLowerCase().trim()];
          const logoUrl = sanityLogo ?? fallbackLogo ?? nameLookup;
          const logoStyle = logoUrl
            ? `background-image:url(${logoUrl});background-size:contain;background-repeat:no-repeat;background-position:center;`
            : undefined;
          return (
            <div class={cardClass} data-category={dataCategory} data-name={card.name}>
              <div class="int-card__logo" style={logoStyle}></div>
              <div class="int-card__info">
                <div class="int-card__name">{card.name}</div>
                <div class="int-card__desc">{card.description}</div>
                {isComingSoon && <span class="int-card__badge">Coming soon</span>}
              </div>
            </div>
          );
        })}

        <div class="int-empty" id="intEmpty">
          <p class="int-empty__text">{emptyLead} {emptyQuestion} <a href={emptyCtaHref}>{emptyCtaLabel}</a> {emptyCtaSuffix}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="api-section" id="apiSection">
    <div class="api-section__inner">
      <div class="api-section__headline">
        <SplitHeadline as="h2" top={apiTop} bottom={apiBottom} />
      </div>
      <div class="api-section__copy">
        <p>{apiBody}</p>
        <a href={apiCtaHref} class="btn btn--primary-light" style="margin-top:1.25rem;display:inline-flex">
          {apiCtaLabel}
        </a>
      </div>
    </div>
  </section>

  <section class="roles-section">
    <div class="roles-section__inner">
      <div class="roles-section__header">
        <SplitHeadline as="h2" top={rolesTop} bottom={rolesBottom} />
      </div>
      <div class="roles-grid">
        {rolesCards.map((card: { title: string; description: string; href: string }, i: number) => (
          <>
            {i > 0 && <div class="roles-divider"></div>}
            <a href={card.href} class="role-item">
              <div class="role-item__title">{card.title}</div>
              <div class="role-item__desc">{card.description}</div>
              <div class="role-item__link">
                Learn more <svg viewBox="0 0 16 16"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
              </div>
            </a>
          </>
        ))}
      </div>
    </div>
  </section>

  <script is:inline src="/components/integrations-inline.js"></script>
</BaseLayout>
