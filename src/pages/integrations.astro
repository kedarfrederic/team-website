---
import BaseLayout from "../layouts/BaseLayout.astro";
import SplitHeadline from "../components/SplitHeadline.astro";
import { getIntegrationsPage, getIntegrations } from "../lib/queries";
import { getClient, urlFor } from "../lib/sanity";

const client = getClient(Astro);
const [page, integrations] = await Promise.all([
  getIntegrationsPage(client),
  getIntegrations(client),
]);

// ── Hero ────────────────────────────────────────────────────
const hero = page?.hero ?? {};
const heroPill = hero.pillLabel ?? "Coming soon";
const heroTop = hero.headlineTop ?? "Every signal";
const heroBottom = hero.headlineBottom ?? "into one strategy";
const heroSubhead =
  hero.subhead ??
  "Team turns the data flowing through your stack — DSPs, social, analytics, ads — into a single coordinated rollout. Native integrations are coming online over the next few months. Here's what's lined up, and how the platform uses each signal.";
const heroBgUrl = hero.backgroundImage?.asset
  ? urlFor(hero.backgroundImage).width(2400).quality(85).format("webp").url()
  : "/header-images/artist-and-manager-with-platform.webp";
const primaryCta = hero.primaryCta ?? { label: "Start your free trial", href: "https://www.teamrollouts.com/sign-up?plan=pro&period=yearly" };
const secondaryCta = hero.secondaryCta ?? { label: "Book a demo", href: "/demo" };

// ── Grid section ────────────────────────────────────────────
const grid = page?.gridSection ?? {};
const gridTop = grid.headlineTop ?? "Every tool you already use";
const gridBottom = grid.headlineBottom ?? "feeding one rollout";
const gridSubhead = grid.subhead ?? "Each integration below maps to a specific moment in the rollout — distribution timing, save velocity, fan engagement, ops handoff. As they come online they become part of the strategy automatically.";
const searchPlaceholder = grid.searchPlaceholder ?? "Search integrations...";

interface FilterPill { label: string; filterKey: string }
const DEFAULT_FILTERS: FilterPill[] = [
  { label: "All", filterKey: "all" },
  { label: "Distribution", filterKey: "distribution" },
  { label: "Social & Marketing", filterKey: "social" },
  { label: "Analytics", filterKey: "analytics" },
  { label: "Productivity", filterKey: "productivity" },
  { label: "Coming Soon", filterKey: "coming-soon" },
];
const filters: FilterPill[] = (Array.isArray(grid.filters) && grid.filters.length > 0)
  ? grid.filters.map((f: any) => ({ label: f?.label ?? "", filterKey: f?.filterKey ?? "all" }))
  : DEFAULT_FILTERS;

const emptyState = grid.emptyState ?? {};
const emptyLead = emptyState.lead ?? "Looks like we don't have that one yet.";
const emptyQuestion = emptyState.ctaQuestion ?? "Need something custom?";
const emptyCtaLabel = emptyState.ctaLabel ?? "Build your own integration";
const emptyCtaSuffix = emptyState.ctaSuffix ?? "with our API.";
const emptyCtaHref = emptyState.ctaHref ?? "#apiSection";

// ── Integration cards: bind to the Sanity collection, fall back to legacy fixtures ──
interface IntegrationDoc {
  _id: string;
  name: string;
  description?: string;
  logo?: any;
  /** External logo URL (used when there's no Sanity-uploaded logo). Pulls
      from cdn.simpleicons.org / svgl.app / jsdelivr — same CDNs the
      homepage marquee uses. */
  logoSrc?: string;
  category: "distribution" | "social" | "analytics" | "productivity";
  comingSoon?: boolean;
  href?: string;
}

// Name → external logo URL lookup. Used as a final fallback when an
// integration has no Sanity-uploaded logo AND no logoSrc field — the
// case for Sanity-seeded integration docs created by scripts/seed-sanity.ts
// (which only writes name/description/category, not the logo). Keyed
// case-insensitive by name.
const LOGO_BY_NAME: Record<string, string> = {
