  "musixmatch":           "https://cdn.simpleicons.org/musixmatch/F8205B",
  "linkfire":             "https://cdn.simpleicons.org/linkfire/00B289",
  "linktree":             "https://cdn.simpleicons.org/linktree/43E55E",
  "feature.fm":           "https://cdn.simpleicons.org/feature/00C2FF",
  "toneden":              "https://cdn.simpleicons.org/toneden/000000",
  "submithub":            "https://cdn.simpleicons.org/submithub/000000",
  "playlist push":        "https://cdn.simpleicons.org/spotify/1ED760",
  "groover":              "https://cdn.simpleicons.org/groover/000000",
  "songkick":             "https://cdn.simpleicons.org/songkick/F80046",
  "bandsintown":          "https://cdn.simpleicons.org/bandsintown/00CEC8",
  "patreon":              "https://cdn.simpleicons.org/patreon/FF424D",
  "gumroad":              "https://cdn.simpleicons.org/gumroad/FF90E8",
