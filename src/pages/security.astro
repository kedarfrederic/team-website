---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSecurityPage } from "../lib/queries";
import { getClient } from "../lib/sanity";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/security-body.html?raw";

const page = await getSecurityPage(getClient(Astro));
---

<BaseLayout
  title={page?.hero?.headline ?? "Security"}
  description="Your releases. Your data. Your rules."
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/security-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/security-inline.js"></script>
</BaseLayout>
