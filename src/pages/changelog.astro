---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getChangelogPage } from "../lib/queries";
import { getClient } from "../lib/sanity";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/changelog-body.html?raw";

const page = await getChangelogPage(getClient(Astro));
---

<BaseLayout
  title={page?.hero?.headline ?? "Changelog"}
  description="What's new in Team."
  seo={page?.seo}
>
  <link slot="head" rel="stylesheet" href="/components/changelog-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/changelog-inline.js"></script>
</BaseLayout>
