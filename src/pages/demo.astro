---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getDemoPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/demo-body.html?raw";

const page = await getDemoPage();
---

<BaseLayout
  title={page?.headline ?? "Book a demo"}
  description={page?.subhead ?? "See how Team can streamline your release workflow."}
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/demo-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/demo-inline.js"></script>
</BaseLayout>
