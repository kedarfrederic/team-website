---
import BaseLayout from "../layouts/BaseLayout.astro";
import IcpPageContent from "../components/pages/IcpPageContent.astro";
import { getIcpPage } from "../lib/queries";

const page = await getIcpPage("forLabelsPage");
---

<BaseLayout
  title={page?.hero?.headline ?? "For Labels"}
  description="Scale your roster. Not your headcount."
  seo={page?.seo}
>
  <IcpPageContent page={page} fallbackTitle="For Labels" />
</BaseLayout>
