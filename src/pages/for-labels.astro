---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getIcpPage } from "../lib/queries";
// @ts-expect-error — ?raw modifier returns string at build time
import bodyHtml from "../lib/for-labels-body.html?raw";

const page = await getIcpPage("forLabelsPage");
---

<BaseLayout
  title={page?.hero?.headline ?? "For Labels"}
  description="Scale your roster. Not your headcount."
  seo={page?.seo}
  navTheme="dark"
>
  <link slot="head" rel="stylesheet" href="/components/for-labels-inline.css" />

  <Fragment set:html={bodyHtml} />

  <script is:inline src="/components/for-labels-inline.js"></script>
</BaseLayout>
