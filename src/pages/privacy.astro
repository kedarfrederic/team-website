---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Privacy Policy">
  <main class="legal-page">
    {/* Top spacer */}
          <div class="h-12 md:h-[71.1111px]" />

          <div class="max-w-full mx-auto px-5 md:max-w-[1400px] md:px-[35.5556px]">
            <div class="max-w-3xl mx-auto">
              <h1 class="text-3xl tracking-tight leading-8 md:text-5xl md:tracking-tighter md:leading-none font-bold text-foreground mb-2">
                Privacy Policy
              </h1>
              <p class="text-xs text-muted-foreground mb-8">Last Updated: December 18, 2025</p>

              <div class="prose prose-gray max-w-none space-y-8">
                {/* Introduction */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">1. Introduction & Scope</h2>
                  <p class="text-foreground mb-4">
                    This Privacy Policy describes how Team Rollouts, Inc. ("Company," "we," "us," or "our") collects, uses, shares, and protects information when you use Team ("Service"), our music release planning and coordination platform.
                  </p>
                  <p class="text-foreground mb-4">
                    This policy applies to all users of the Service, including artists, managers, label representatives, and team members who access the platform through web browsers or mobile devices.
                  </p>
                  <p class="text-foreground">
                    By using Team, you agree to the collection and use of information in accordance with this policy. If you do not agree with our practices, please do not use the Service.
                  </p>
                </section>

                {/* Data We Collect */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">2. Information We Collect</h2>

                  <h3 class="text-lg font-medium text-foreground mb-3">Personal Information</h3>
                  <p class="text-foreground mb-4">
                    When you create an account or use our Service, we collect:
                  </p>
                  <ul class="list-disc pl-6 text-foreground mb-4 space-y-2">
                    <li><strong>Account Information:</strong>Name, email address, profile picture, and authentication credentials</li>
                    <li><strong>Contact Information:</strong>Phone number (for SMS notifications), mailing address (if provided)</li>
                    <li><strong>Organization Information:</strong>Team name, role within organization, artist or label affiliation</li>
                    <li><strong>Payment Information:</strong>Billing address and payment method details (processed securely by our payment processor)</li>
                  </ul>

                  <h3 class="text-lg font-medium text-foreground mb-3">Release and Project Data</h3>
                  <p class="text-foreground mb-4">
                    To provide our release planning services, we collect:
                  </p>
                  <ul class="list-disc pl-6 text-foreground mb-4 space-y-2">
                    <li><strong>Release Information:</strong>Artist names, release titles, genres, release dates, and promotional budgets</li>
                    <li><strong>Task and Timeline Data:</strong>Tasks, deadlines, assignments, comments, and completion status</li>
                    <li><strong>Uploaded Content:</strong>Documents, images, audio files, press materials, and other assets you upload</li>
                    <li><strong>Budget Information:</strong>Budget allocations, spending records, and financial planning data</li>
                  </ul>

                  <h3 class="text-lg font-medium text-foreground mb-3">Communications Data</h3>
                  <ul class="list-disc pl-6 text-foreground mb-4 space-y-2">
                    <li><strong>Email Integration:</strong>When you connect email accounts (Gmail, Outlook), we access email metadata and content to surface release-related communications within the platform</li>
                    <li><strong>AI Conversations:</strong>Messages exchanged with our AI assistant (Teammate) to provide personalized assistance</li>
                    <li><strong>Team Communications:</strong>Comments, mentions, and notifications shared within your organization</li>
                  </ul>

                  <h3 class="text-lg font-medium text-foreground mb-3">Usage and Technical Data</h3>
                  <ul class="list-disc pl-6 text-foreground mb-4 space-y-2">
                    <li><strong>Device Information:</strong>Browser type, operating system, device identifiers</li>
                    <li><strong>Log Data:</strong>IP address, access times, pages viewed, features used</li>
                    <li><strong>Analytics Data:</strong>Feature usage patterns, session duration, interaction data</li>
                    <li><strong>Performance Data:</strong>Error logs and diagnostic information</li>
                  </ul>

                  <h3 class="text-lg font-medium text-foreground mb-3">Third-Party Integration Data</h3>
                  <p class="text-foreground mb-4">
                    When you connect third-party services, we may receive:
                  </p>
                  <ul class="list-disc pl-6 text-foreground space-y-2">
                    <li><strong>Spotify:</strong>Artist profiles, streaming analytics, playlist placements</li>
                    <li><strong>Social Platforms:</strong>Account connections for posting and analytics</li>
                    <li><strong>Calendar Services:</strong>Event and scheduling data</li>
                  </ul>
                </section>

                {/* How We Collect */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">3. How We Collect Information</h2>

                  <h3 class="text-lg font-medium text-foreground mb-3">Direct Collection</h3>
                  <p class="text-foreground mb-4">
                    We collect information directly when you create an account, fill out forms, upload content, connect integrations, or communicate with us.
                  </p>

                  <h3 class="text-lg font-medium text-foreground mb-3">Automatic Collection</h3>
                  <p class="text-foreground mb-4">
                    We automatically collect technical and usage data through cookies, analytics tools, and server logs when you interact with the Service.
                  </p>

                  <h3 class="text-lg font-medium text-foreground mb-3">Third-Party Sources</h3>
                  <p class="text-foreground">
                    We receive information from third-party services you connect (email providers, streaming platforms, social networks) and from authentication providers (Clerk) when you sign in.
                  </p>
                </section>

                {/* How We Use Data */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">4. How We Use Your Information</h2>
                  <p class="text-foreground mb-4">We use collected information to:</p>
                  <ul class="list-disc pl-6 text-foreground space-y-2">
                    <li><strong>Provide the Service:</strong>Enable release planning, task management, team collaboration, and AI assistance</li>
                    <li><strong>Personalize Experience:</strong>Customize recommendations, suggestions, and AI responses based on your release context</li>
                    <li><strong>Process Transactions:</strong>Handle subscription payments and billing</li>
                    <li><strong>Send Communications:</strong>Deliver account notifications, task reminders, and customer support via email and SMS</li>
                    <li><strong>Improve the Service:</strong>Analyze usage patterns to enhance features, fix bugs, and develop new capabilities</li>
                    <li><strong>Ensure Security:</strong>Detect and prevent fraud, abuse, and unauthorized access</li>
                    <li><strong>Comply with Legal Obligations:</strong>Meet regulatory requirements and respond to legal requests</li>
                  </ul>
                </section>

                {/* SMS Specific */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">5. SMS Text Messages</h2>
                  <p class="text-foreground mb-4">
                    If you provide your mobile phone number and opt in to receive text messages:
                  </p>
                  <ul class="list-disc pl-6 text-foreground mb-4 space-y-2">
                    <li><strong>Purpose:</strong>Text messages are sent solely for account-related notifications and customer support related to release planning, coordination, and execution. We do not send marketing or promotional text messages.</li>
                    <li><strong>Consent:</strong>You may opt in during account registration or within authenticated account settings. Consent is not a condition of purchase.</li>
                    <li><strong>Frequency:</strong>Message frequency varies depending on your activity and account interactions.</li>
                    <li><strong>Opt-Out:</strong>Reply STOP at any time to stop receiving text messages.</li>
                    <li><strong>Help:</strong>Reply HELP for assistance.</li>
                    <li><strong>Fees:</strong>Message and data rates may apply depending on your mobile carrier and plan.</li>
                  </ul>
                  <p class="text-foreground">
                    <strong>Mobile phone numbers and SMS messaging data will not be shared with third parties for marketing or promotional purposes.</strong>
                  </p>
                </section>

                {/* Data Sharing */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">6. Data Sharing & Third Parties</h2>
                  <p class="text-foreground mb-4">
                    <strong>We do not sell your personal information.</strong>We share data only in the following circumstances:</p>

                  <h3 class="text-lg font-medium text-foreground mb-3">Service Providers (Subprocessors)</h3>
                  <p class="text-foreground mb-4">
                    We use trusted third-party services to operate the platform:
                  </p>
                  <ul class="list-disc pl-6 text-foreground mb-4 space-y-2">
                    <li><strong>Cloud Infrastructure:</strong>Neon (database), Cloudflare (storage, CDN)</li>
                    <li><strong>Authentication:</strong>Clerk (user authentication and identity)</li>
                    <li><strong>AI Services:</strong>OpenRouter (AI model access for Teammate assistant)</li>
                    <li><strong>Analytics:</strong>Sentry (error monitoring), Umami (privacy-focused analytics)</li>
                    <li><strong>Scheduling:</strong>Calendly (demo booking and scheduling — when you book a demo, Calendly collects your name, email, and scheduling preferences per their own privacy policy)</li>
                    <li><strong>Advertising:</strong>Meta Pixel (conversion tracking and ad optimization for Meta/Facebook/Instagram advertising campaigns)</li>
                    <li><strong>Communications:</strong>Twilio (SMS), SendGrid (email)</li>
                    <li><strong>Payments:</strong>Stripe (payment processing)</li>
                  </ul>

                  <h3 class="text-lg font-medium text-foreground mb-3">Within Your Organization</h3>
                  <p class="text-foreground mb-4">
                    Release data, tasks, and communications are shared with other members of your organization as part of the collaboration features.
                  </p>

                  <h3 class="text-lg font-medium text-foreground mb-3">Legal Requirements</h3>
                  <p class="text-foreground">
                    We may disclose information when required by law, court order, or government request, or to protect our rights, safety, or property.
                  </p>
                </section>

                {/* Cookies */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">7. Cookies & Tracking Technologies</h2>
                  <p class="text-foreground mb-4">We use cookies and similar technologies for:</p>
                  <ul class="list-disc pl-6 text-foreground mb-4 space-y-2">
                    <li><strong>Essential Cookies:</strong>Required for authentication, security, and core functionality</li>
                    <li><strong>Preference Cookies:</strong>Remember your settings and preferences</li>
                    <li><strong>Analytics Cookies:</strong>Help us understand how users interact with the Service</li>
                    <li><strong>Marketing Cookies:</strong>Used by Meta Pixel and similar advertising tools to measure ad performance, optimize campaigns, and build retargeting audiences. These cookies are only activated with your consent via our cookie banner</li>
                  </ul>
                  <p class="text-foreground">
                    You can control cookies through your browser settings or our cookie preference banner. Disabling certain cookies may affect Service functionality. Marketing cookies are disabled by default and require your explicit consent.
                  </p>
                </section>

                {/* Legal Bases */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">8. Legal Bases & Global Privacy Laws</h2>

                  <h3 class="text-lg font-medium text-foreground mb-3">GDPR (European Users)</h3>
                  <p class="text-foreground mb-4">
                    For users in the European Economic Area, we process data based on: contract performance, legitimate interests, consent, and legal obligations.
                  </p>

                  <h3 class="text-lg font-medium text-foreground mb-3">CCPA (California Users)</h3>
                  <p class="text-foreground mb-4">
                    California residents have rights to know, delete, and opt-out. We do not sell personal information. To exercise your rights, contact us at legal@teamrollouts.com.
                  </p>

                  <h3 class="text-lg font-medium text-foreground mb-3">Other Jurisdictions</h3>
                  <p class="text-foreground">
                    We comply with applicable privacy laws in jurisdictions where we operate and will honor reasonable requests from users worldwide.
                  </p>
                </section>

                {/* Data Retention */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">9. Data Retention & Deletion</h2>
                  <p class="text-foreground mb-4">
                    We retain your data for as long as your account is active or as needed to provide services:
                  </p>
                  <ul class="list-disc pl-6 text-foreground mb-4 space-y-2">
                    <li><strong>Account Data:</strong>Retained while your account is active; deleted within 30 days of account deletion request</li>
                    <li><strong>Release Data:</strong>Retained for the duration of your subscription; archived releases may be retained for 1 year after subscription ends</li>
                    <li><strong>AI Conversation History:</strong>Retained based on your subscription tier (1-30 days for standard tiers)</li>
                    <li><strong>Analytics Data:</strong>Aggregated and anonymized data may be retained indefinitely</li>
                  </ul>
                  <p class="text-foreground">
                    To request data deletion, contact us at legal@teamrollouts.com or use the account deletion feature in Settings.
                  </p>
                </section>

                {/* User Rights */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">10. Your Rights</h2>
                  <p class="text-foreground mb-4">You have the right to:</p>
                  <ul class="list-disc pl-6 text-foreground mb-4 space-y-2">
                    <li><strong>Access:</strong>Request a copy of your personal data</li>
                    <li><strong>Correction:</strong>Update or correct inaccurate information</li>
                    <li><strong>Deletion:</strong>Request deletion of your personal data</li>
                    <li><strong>Export:</strong>Receive your data in a portable format</li>
                    <li><strong>Restriction:</strong>Limit how we process your data</li>
                    <li><strong>Objection:</strong>Object to certain processing activities</li>
                    <li><strong>Withdraw Consent:</strong>Revoke previously given consent</li>
                  </ul>
                  <p class="text-foreground">
                    To exercise these rights, contact us at legal@teamrollouts.com. We will respond within 30 days.
                  </p>
                </section>

                {/* Security */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">11. Security Practices</h2>
                  <p class="text-foreground mb-4">
                    We implement industry-standard security measures to protect your data:
                  </p>
                  <ul class="list-disc pl-6 text-foreground space-y-2">
                    <li><strong>Encryption:</strong>Data encrypted in transit (TLS) and at rest</li>
                    <li><strong>Access Controls:</strong>Role-based access and authentication requirements</li>
                    <li><strong>Infrastructure Security:</strong>Hosted on secure cloud infrastructure with regular security audits</li>
                    <li><strong>Monitoring:</strong>Continuous monitoring for suspicious activity and security threats</li>
                    <li><strong>Employee Training:</strong>Staff trained on data protection and security practices</li>
                  </ul>
                </section>

                {/* Children */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">12. Children's Privacy</h2>
                  <p class="text-foreground">
                    The Service is not intended for users under 16 years of age. We do not knowingly collect personal information from children. If you believe we have collected information from a child, please contact us immediately.
                  </p>
                </section>

                {/* Changes */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">13. Changes to This Policy</h2>
                  <p class="text-foreground">
                    We may update this Privacy Policy from time to time. We will notify you of material changes by posting the updated policy on this page and updating the "Last Updated" date. For significant changes, we may also send an email notification. Your continued use of the Service after changes constitutes acceptance of the updated policy.
                  </p>
                </section>

                {/* Contact */}
                <section>
                  <h2 class="text-lg tracking-tight leading-snug md:text-xl md:tracking-tight md:leading-tight font-semibold text-foreground mb-4">14. Contact Us</h2>
                  <p class="text-foreground mb-4">
                    For privacy-related questions or to exercise your rights, contact us:
                  </p>
                  <div class="border border-border p-4 text-foreground">
                    <p><strong>Team Rollouts, Inc.</strong></p>
                    <p>Email: legal@teamrollouts.com</p>
                    <p>Subject: Privacy Inquiry</p>
                  </div>
                </section>
              </div>
            </div>
          </div>

          {/* Bottom spacer */}
          <div class="h-12 md:h-[71.1111px]" />
  </main>
</BaseLayout>

<style>
  .legal-page {
    background: var(--bg);
    padding: 6rem 2rem 4rem;
  }
  .legal-page :global(h1) {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    letter-spacing: -0.02em;
    line-height: 1.1;
    color: var(--black);
    margin-bottom: 0.5rem;
  }
  .legal-page :global(h2) {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--black);
    margin: 2.5rem 0 1rem;
  }
  .legal-page :global(h3) {
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--black);
    margin: 1.5rem 0 0.75rem;
  }
  .legal-page :global(p),
  .legal-page :global(li) {
    color: var(--text-secondary);
    line-height: 1.6;
    font-size: 0.9375rem;
    margin-bottom: 0.75rem;
  }
  .legal-page :global(ul) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }
  .legal-page :global(strong) {
    color: var(--black);
    font-weight: 600;
  }
  .legal-page :global(.max-w-3xl) {
    max-width: 48rem;
    margin-inline: auto;
  }
  .legal-page :global(.text-xs) {
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
</style>
