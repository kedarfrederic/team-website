# Marketing site env. Copy to .env (not committed) for local dev.
#
# These two enable the Sanity Visual Editing flow:

# Read token (Viewer role) for fetching drafts in preview mode.
# Create at: manage.sanity.io → API → Tokens → Add API token (Viewer)
# REQUIRED for preview mode to show unpublished edits. If absent, preview
# falls back to the published client.
SANITY_API_READ_TOKEN=

# Shared secret that gates `/api/preview/enable`. Studio embeds this in
# the preview-mode URL so arbitrary visitors can't flip themselves into
# preview. Generate any random string (32+ chars). Must match
# SANITY_STUDIO_PREVIEW_SECRET in /sanity/.env.
SANITY_PREVIEW_SECRET=

# Hosted Studio URL for stega-encoded click-to-edit links. In dev this
# points at the local studio (http://localhost:3333); in prod, set to
# the deployed Studio URL (e.g. https://team-cms.sanity.studio).
PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
