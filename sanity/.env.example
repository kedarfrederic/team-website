# Sanity Studio env. Copy to .env (not committed).
#
# Studio variables MUST be prefixed with SANITY_STUDIO_ to be exposed in
# the bundled Studio app. Other env vars stay server-only.

# URL of the deployed marketing site that Studio's Presentation tool will
# load in its preview iframe. Local dev: http://localhost:4321. Prod:
# https://teamrollouts.com (or the staging origin).
SANITY_STUDIO_PREVIEW_URL=http://localhost:4321

# Shared secret matching SANITY_PREVIEW_SECRET on the marketing site.
# Studio sends this on /api/preview/enable to authorize draft access.
SANITY_STUDIO_PREVIEW_SECRET=
